---
import PageHeader from "../../../components/PageHeader.astro";
import Layout from "../../../layouts/Layout.astro";
import { getPage } from "../../../utils";

const page = await getPage("data-source");

const title = page.title_cn || page.title;
const description = page.description_cn || page.description;
const keywords = page.keywords_cn || page.keywords;
---

<Layout title={title} description={description} keywords={keywords}>
  <PageHeader title={title}>
    <span slot="description" set:html={description}></span>
  </PageHeader>
  <!-- Start Highlights -->
  <section class="section">
    <div class="container">
      <div class="row align-items-top ">
        <div class="col-lg-5 col-md-5">
          <div class="section-title">
            <h5 class="mb-4">同時連接<span class="text-primary">多個數據源</span>，統一管理企業數據</h5>
            <p class="text-muted">數據散落在 CRM、ERP、財務與庫存等系統。統一接入 NocoBase，多源數據在同一界面被整合與查詢，減少跨系統切換，打破系統間隔閡，顯著降低維護成本。</p>
          </div>
        </div><!--end col-->
        <div class="col-lg-7">
          <div class="card rounded border-0 shadow ms-lg-5">
            <video controls class="rounded shadow">
              <source src="https://static-docs.nocobase.com/DS-1.1-CN.mp4" type="video/mp4">
            </video>
          </div>
        </div><!--end col-->
      </div><!--end row-->
      <div class="row align-items-top mt-100">
        <div class="col-lg-5 col-md-5">
          <div class="section-title">
            <h5 class="mb-4">通過<span class="text-primary">事件流</span>在前端連通不同數據源</h5>
            <p class="text-muted">當一個頁面中有多個數據源的區塊時，可以使用事件流來編排他們之間的交互邏輯，在前端實現多個數據源的數據之間發生聯動。比如在 CRM 中查看客戶時，需要同時從 ERP 中查詢出該客戶的訂單記錄。</p>
          </div>
        </div><!--end col-->
        <div class="col-lg-7">
          <div class="card rounded border-0 shadow ms-lg-5">
            <video controls class="rounded shadow">
              <source src="https://static-docs.nocobase.com/DS-1.2-CN.mp4" type="video/mp4">
            </video>
          </div>
        </div><!--end col-->
      </div><!--end row-->
      <div class="row align-items-top mt-100">
        <div class="col-lg-5 col-md-5">
          <div class="section-title">
            <h5 class="mb-4">通過<span class="text-primary">工作流</span>在後端連通不同數據源</h5>
            <p class="text-muted">當一個 NocoBase 應用中有多個數據源時，可以使用工作流來編排它們之間的流程邏輯，在後端實現多個數據源之間的業務自動化。比如在 ERP 中新增訂單時，需要將 CRM 中該客戶的等級提升為 “付費客戶”。</p>
          </div>
        </div><!--end col-->
        <div class="col-lg-7">
          <div class="card rounded border-0 shadow ms-lg-5">
            <video controls class="rounded shadow">
              <source src="https://static-docs.nocobase.com/DS-1.3-CN.mp4" type="video/mp4">
            </video>
          </div>
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
  <!-- Highlights End -->
</Layout>