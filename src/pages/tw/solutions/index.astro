---
import BaseTW from "../../../layouts/BaseTW.astro";
import ShapeFooter from "../../../components/ShapeFooter.astro";

// 方案庫 — 後續上新方案只需往這裡追加一條
const solutions = [
  {
    title: "一體化業務管理系統",
    desc: "CRM、銷售、工單、專案、固定資產、HR 六大模組整合在同一系統內,內建 AI 員工與工作流。",
    href: "/tw/solutions/all-in-one",
    cover: "https://static-docs.nocobase.com/all-in-one-cover-2026-05-20.jpg",
    icon: "uil-layer-group",
    categories: ["一體化"],
    status: "更新中",
    tags: ["一體化", "多業務線", "AI 員工"],
  },
  {
    title: "CRM 升級版",
    desc: "線索、跟進、轉化、客戶 360 的完整銷售閉環,模組可拆解,深度融合 AI 員工,內建多幣別與儀表板。",
    href: "/tw/solutions/crm-v2",
    cover: "https://static-docs.nocobase.com/design-2026-02-01-02-46-56-opt.jpg",
    icon: "uil-chart-growth",
    categories: ["客戶與銷售"],
    tags: ["CRM", "銷售管理", "客戶 360"],
  },
  {
    title: "CRM 基礎版",
    desc: "靈活、可深度客製的 CRM 基礎框架,完全掌握資料主權,可在此之上擴充改造。",
    href: "/tw/solutions/crm",
    cover: "https://static-docs.nocobase.com/img_v3_02o3_58bedc3b-7f22-4b56-9c74-83463ffb186g32-opt.jpeg",
    icon: "uil-users-alt",
    categories: ["客戶與銷售"],
    tags: ["CRM", "可客製", "基座"],
  },
  {
    title: "智能工單系統 2.0",
    desc: "客戶報障到結案的完整生命週期,T 型資料架構支援多業務場景,AI 員工輔助分類與處理。",
    href: "/tw/solutions/ticketing-v2",
    cover: "https://static-docs.nocobase.com/ticketing-imgs-2026-01-01-00-46-12-opt.jpg",
    icon: "uil-robot",
    categories: ["客戶服務"],
    tags: ["工單", "客服", "AI 分類"],
  },
  {
    title: "工單管理系統（1.x）",
    desc: "作為 CRM 的重要補充,提供完整的工單生命週期管理,適合售後與客服場景。",
    href: "/tw/solutions/ticketing",
    cover: "https://static-docs.nocobase.com/img_v3_02o5_a2422688-f176-4c84-bf32-5ee0774f919g-1.png",
    icon: "uil-comment-alt-lines",
    categories: ["客戶服務"],
    tags: ["工單", "售後", "1.x"],
  },
  {
    title: "專案管理（1.x）",
    desc: "從需求到交付的專案全生命週期管理,涵蓋任務、迭代、進度、里程碑與工作量。",
    href: "/tw/solutions/project-management",
    cover: "https://static-docs.nocobase.com/screenshot-20250909-151855-1.png",
    icon: "uil-clipboard-notes",
    categories: ["專案與研發"],
    tags: ["專案", "研發協作", "里程碑", "1.x"],
  },
];

// 篩選分類(順序即展示順序)
const categories = ["全部", "一體化", "客戶與銷售", "客戶服務", "專案與研發"];
---

<BaseTW
  title="更多方案 - NocoBase 解決方案庫"
  description="NocoBase 解決方案庫:一體化業務管理系統,以及 CRM、銷售、工單、專案管理等獨立業務方案,按場景篩選,均基於 NocoBase 無程式碼平台,開箱即用、可自部署。"
  keywords="NocoBase 解決方案, 解決方案庫, 一體化業務管理系統, CRM 系統, 工單系統, 專案管理系統, 無程式碼方案, 開源業務系統"
>
  <!-- Hero Start -->
  <section class="bg-half-170 bg-light d-table w-100">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 text-center">
          <div class="title-heading">
            <h1 class="title fw-bold mb-3">解決方案庫</h1>
            <p class="para-desc mx-auto text-muted mb-0">
              基於 NocoBase 無程式碼平台沉澱的業務方案,按場景挑選適合你的那一套。全部開箱即用、支援自部署,更多方案持續上線中。
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- Hero End -->

  <!-- Solutions Gallery Start -->
  <section class="section">
    <div class="container">
      <!-- 篩選 chips -->
      <div class="row justify-content-center">
        <div class="col-12 text-center mb-4">
          <ul class="solution-filter list-unstyled mb-0" id="solution-filter">
            {categories.map((cat, i) => (
              <li
                class:list={["filter-chip", { active: i === 0 }]}
                data-filter={cat === "全部" ? "*" : cat}
              >{cat}</li>
            ))}
          </ul>
        </div>
      </div>

      <!-- 卡片網格 -->
      <div class="row" id="solution-grid">
        {solutions.map((s) => (
          <div class="col-lg-4 col-md-6 mt-4 pt-2 solution-item" data-categories={s.categories.join(",")}>
            <div class="card border-0 shadow h-100 d-flex flex-column solution-card overflow-hidden">
              <div class="sol-cover-wrap">
                <img src={s.cover} alt={s.title} class="sol-cover" loading="lazy" />
              </div>
              <div class="p-4 d-flex flex-column flex-grow-1">
                <h5 class="title text-dark mb-0">{s.title}</h5>
                <p class="text-muted mt-2 sol-desc">{s.desc}</p>
                <a href={s.href} class="text-primary small d-inline-block stretched-link">查看方案 <i class="uil uil-arrow-right"></i></a>
                <div class="solution-tags mt-3 pt-3 border-top">
                  {s.tags.map((t) => <span class="sol-tag">{t}</span>)}
                  {s.status && <span class="sol-tag sol-tag-status">{s.status}</span>}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- 空狀態(暫未匹配) -->
      <div class="row" id="solution-empty" style="display:none;">
        <div class="col-12 text-center text-muted py-5">
          <i class="uil uil-search-minus h3 d-block mb-2"></i>該分類暫無方案,更多方案上線中。
        </div>
      </div>
    </div>
  </section>
  <!-- Solutions Gallery End -->

  <ShapeFooter />

  <style>
    .solution-filter {
      display: inline-flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: center;
    }
    .filter-chip {
      cursor: pointer;
      padding: 6px 18px;
      border-radius: 30px;
      font-size: 14px;
      color: #6c757d;
      background: #f4f6fa;
      transition: all 0.2s ease;
      user-select: none;
    }
    .filter-chip:hover {
      color: #2f55d4;
      background: rgba(47, 85, 212, 0.08);
    }
    .filter-chip.active {
      color: #fff;
      background: #2f55d4;
    }
    .solution-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .sol-tag {
      font-size: 12px;
      padding: 2px 10px;
      border-radius: 20px;
      background: rgba(47, 85, 212, 0.1);
      color: #2f55d4;
      line-height: 1.6;
    }
    .sol-tag-status {
      background: rgba(46, 202, 139, 0.12);
      color: #2eca8b;
    }
    .sol-desc {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin-bottom: 1rem;
    }
    .solution-card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .solution-card:hover {
      transform: translateY(-4px);
    }
    .sol-cover-wrap {
      position: relative;
      width: 100%;
      height: 180px;
      overflow: hidden;
      background: #f4f6fa;
    }
    .sol-cover {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }
    .solution-card:hover .sol-cover {
      transform: scale(1.05);
    }
  </style>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const chips = document.querySelectorAll("#solution-filter .filter-chip");
      const items = document.querySelectorAll("#solution-grid .solution-item");
      const empty = document.getElementById("solution-empty");

      chips.forEach((chip) => {
        chip.addEventListener("click", () => {
          chips.forEach((c) => c.classList.remove("active"));
          chip.classList.add("active");
          const filter = chip.getAttribute("data-filter");
          let visible = 0;
          items.forEach((item) => {
            const cats = (item.getAttribute("data-categories") || "").split(",");
            const show = filter === "*" || cats.includes(filter);
            item.style.display = show ? "" : "none";
            if (show) visible++;
          });
          if (empty) empty.style.display = visible === 0 ? "" : "none";
        });
      });
    });
  </script>
</BaseTW>
