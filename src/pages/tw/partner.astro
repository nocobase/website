---
import BaseTW from "../../layouts/BaseTW.astro";
import ShapeFooter from "../../components/ShapeFooter.astro";
---

<BaseTW
  title="NocoBase 合作伙伴計劃 - 與 NocoBase 共贏增長"
  description="加入 NocoBase 合作伙伴計劃。渠道銷售最高可獲 40% 佣金，服務收入 100% 歸您所有。兩種靈活合作模式，專為系統集成商、諮詢公司和技術服務商設計。"
  keywords="NocoBase 合作伙伴, 合作伙伴計劃, 渠道夥伴, 服務夥伴, 經銷商, 系統集成商"
>
  <!-- Hero/Banner Start -->
  <section class="bg-half-170 bg-light d-table w-100">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 text-center">
          <div class="title-heading">
            <span class="badge bg-soft-primary mb-3">合作伙伴計劃</span>
            <h1 class="fw-bold mt-2 mb-3">與 NocoBase 一起增長共贏</h1>
            <p class="para-desc mx-auto text-muted">兩種靈活的合作模式，渠道銷售最高可獲 40% 階梯佣金，服務收入 100% 歸您所有。無論您專注分銷、實施還是兩者兼顧，我們攜手共進。</p>
            <div class="mt-4 pt-2">
              <a href="mailto:partner@nocobase.com" class="btn btn-primary me-3">
                <i class="uil uil-envelope me-1"></i>聯繫我們
              </a>
              <a href="#partnership-models" class="btn btn-outline-primary">
                <i class="uil uil-arrow-down me-1"></i>瞭解詳情
              </a>
            </div>
          </div>
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
  <!-- Hero/Banner End -->

  <!-- Partnership Models Start -->
  <section class="section" id="partnership-models">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12">
          <div class="section-title text-center mb-4 pb-2">
            <h4 class="title mb-4">兩種靈活的合作模式</h4>
            <p class="para-desc mx-auto text-muted mb-0">選擇一種模式或兩者兼顧，最大化您的收益</p>
          </div>
        </div><!--end col-->
      </div><!--end row-->

      <div class="row">
        <div class="col-lg-6 col-md-6 mt-4 pt-2">
          <div class="card border-0 shadow rounded h-100 p-4">
            <div class="d-flex align-items-center mb-3">
              <div class="icons text-start me-3">
                <i class="uil uil-store rounded h3 mb-0 text-primary"></i>
              </div>
              <h5 class="mb-0">渠道分銷</h5>
            </div>
            <p class="text-muted">推廣和銷售 NocoBase 產品，根據終身累計銷售額獲取階梯佣金。</p>
            <ul class="list-unstyled">
              <li class="d-flex align-items-start mb-3">
                <i class="uil uil-arrow-right text-primary me-2"></i>
                <span><strong>15% - 40%</strong> 階梯佣金比例</span>
              </li>
              <li class="d-flex align-items-start mb-3">
                <i class="uil uil-arrow-right text-primary me-2"></i>
                <span>終身累計，無時間限制</span>
              </li>
              <li class="d-flex align-items-start mb-3">
                <i class="uil uil-arrow-right text-primary me-2"></i>
                <span>佣金比例只升不降</span>
              </li>
              <li class="d-flex align-items-start mb-0">
                <i class="uil uil-arrow-right text-primary me-2"></i>
                <span>提供銷售賦能資料</span>
              </li>
            </ul>
          </div>
        </div><!--end col-->

        <div class="col-lg-6 col-md-6 mt-4 pt-2">
          <div class="card border-0 shadow rounded h-100 p-4">
            <div class="d-flex align-items-center mb-3">
              <div class="icons text-start me-3">
                <i class="uil uil-setting rounded h3 mb-0 text-primary"></i>
              </div>
              <h5 class="mb-0">服務實施</h5>
            </div>
            <p class="text-muted">提供部署、定製、集成和培訓服務，獲取基於項目的服務收入。</p>
            <ul class="list-unstyled">
              <li class="d-flex align-items-start mb-3">
                <i class="uil uil-arrow-right text-primary me-2"></i>
                <span>服務收入 <strong>100%</strong> 歸您所有，無需向 NocoBase 支付費用</span>
              </li>
              <li class="d-flex align-items-start mb-3">
                <i class="uil uil-arrow-right text-primary me-2"></i>
                <span>服務定價完全自主</span>
              </li>
              <li class="d-flex align-items-start mb-3">
                <i class="uil uil-arrow-right text-primary me-2"></i>
                <span>根據交付項目數量晉級</span>
              </li>
              <li class="d-flex align-items-start mb-0">
                <i class="uil uil-arrow-right text-primary me-2"></i>
                <span>高級別夥伴享受優先商機推薦</span>
              </li>
            </ul>
          </div>
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
  <!-- Partnership Models End -->

  <!-- Why Partner Start -->
  <section class="section">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12">
          <div class="section-title text-center mb-4 pb-2">
            <h4 class="title mb-4">為什麼選擇 NocoBase</h4>
            <p class="para-desc mx-auto text-muted mb-0">為高價值項目打造的產品，具備強大的夥伴經濟模型</p>
          </div>
        </div><!--end col-->
      </div><!--end row-->

      <div class="row">
        <div class="col-lg-4 col-md-6 mt-4 pt-2">
          <div class="card border-0 features feature-primary feature-clean course-feature p-4 overflow-hidden shadow h-100">
            <div class="icons text-start">
              <i class="uil uil-database rounded h3 mb-0"></i>
            </div>
            <div class="card-body p-0 mt-4">
              <h5 class="title text-dark">數據模型驅動</h5>
              <p class="text-muted mt-2">支撐複雜業務邏輯，項目天花板高，適合承接大型企業合同。</p>
              <i class="uil uil-database full-img"></i>
            </div>
          </div>
        </div><!--end col-->

        <div class="col-lg-4 col-md-6 mt-4 pt-2">
          <div class="card border-0 features feature-primary feature-clean course-feature p-4 overflow-hidden shadow h-100">
            <div class="icons text-start">
              <i class="uil uil-cube rounded h3 mb-0"></i>
            </div>
            <div class="card-body p-0 mt-4">
              <h5 class="title text-dark">插件化架構</h5>
              <p class="text-muted mt-2">高度可定製，服務空間大。深度定製驅動高毛利的服務收入。</p>
              <i class="uil uil-cube full-img"></i>
            </div>
          </div>
        </div><!--end col-->

        <div class="col-lg-4 col-md-6 mt-4 pt-2">
          <div class="card border-0 features feature-primary feature-clean course-feature p-4 overflow-hidden shadow h-100">
            <div class="icons text-start">
              <i class="uil uil-lock-open-alt rounded h3 mb-0"></i>
            </div>
            <div class="card-body p-0 mt-4">
              <h5 class="title text-dark">開源透明</h5>
              <p class="text-muted mt-2">代碼完全開放，深度定製無障礙。技術風險低，客戶信任度高。</p>
              <i class="uil uil-lock-open-alt full-img"></i>
            </div>
          </div>
        </div><!--end col-->

        <div class="col-lg-4 col-md-6 mt-4 pt-2">
          <div class="card border-0 features feature-primary feature-clean course-feature p-4 overflow-hidden shadow h-100">
            <div class="icons text-start">
              <i class="uil uil-dollar-sign rounded h3 mb-0"></i>
            </div>
            <div class="card-body p-0 mt-4">
              <h5 class="title text-dark">一次性授權</h5>
              <p class="text-muted mt-2">不限用戶數和應用數，客戶成本可控，更容易促成簽單。</p>
              <i class="uil uil-dollar-sign full-img"></i>
            </div>
          </div>
        </div><!--end col-->

        <div class="col-lg-4 col-md-6 mt-4 pt-2">
          <div class="card border-0 features feature-primary feature-clean course-feature p-4 overflow-hidden shadow h-100">
            <div class="icons text-start">
              <i class="uil uil-robot rounded h3 mb-0"></i>
            </div>
            <div class="card-body p-0 mt-4">
              <h5 class="title text-dark">AI 原生</h5>
              <p class="text-muted mt-2">內置 AI 能力，契合企業 AI 轉型趨勢，是有力的差異化賣點。</p>
              <i class="uil uil-robot full-img"></i>
            </div>
          </div>
        </div><!--end col-->

        <div class="col-lg-4 col-md-6 mt-4 pt-2">
          <div class="card border-0 features feature-primary feature-clean course-feature p-4 overflow-hidden shadow h-100">
            <div class="icons text-start">
              <i class="uil uil-shield-check rounded h3 mb-0"></i>
            </div>
            <div class="card-body p-0 mt-4">
              <h5 class="title text-dark">數據完全掌控</h5>
              <p class="text-muted mt-2">私有化部署，代碼和數據完全自主。滿足企業安全合規要求。</p>
              <i class="uil uil-shield-check full-img"></i>
            </div>
          </div>
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
  <!-- Why Partner End -->

  <!-- Partner Support Start -->
  <section class="section bg-light">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12">
          <div class="section-title text-center mb-4 pb-2">
            <h4 class="title mb-4">全方位支持體系</h4>
            <p class="para-desc mx-auto text-muted mb-0">豐富的資源和支持助您成功</p>
          </div>
        </div><!--end col-->
      </div><!--end row-->

      <div class="row">
        <div class="col-lg-3 col-md-6 mt-4 pt-2">
          <div class="card border-0 text-center features feature-clean course-feature p-4 shadow h-100">
            <div class="icons text-center">
              <i class="uil uil-file-alt h1 text-primary"></i>
            </div>
            <div class="content mt-4">
              <h5>銷售賦能</h5>
              <p class="text-muted mt-2">產品物料、宣傳手冊、客戶案例和競品分析資料</p>
            </div>
          </div>
        </div><!--end col-->

        <div class="col-lg-3 col-md-6 mt-4 pt-2">
          <div class="card border-0 text-center features feature-clean course-feature p-4 shadow h-100">
            <div class="icons text-center">
              <i class="uil uil-headphones h1 text-primary"></i>
            </div>
            <div class="content mt-4">
              <h5>技術支持</h5>
              <p class="text-muted mt-2">專屬支持通道，高級別夥伴享受優先響應</p>
            </div>
          </div>
        </div><!--end col-->

        <div class="col-lg-3 col-md-6 mt-4 pt-2">
          <div class="card border-0 text-center features feature-clean course-feature p-4 shadow h-100">
            <div class="icons text-center">
              <i class="uil uil-users-alt h1 text-primary"></i>
            </div>
            <div class="content mt-4">
              <h5>商機推薦</h5>
              <p class="text-muted mt-2">NocoBase 官方客戶推薦，高級夥伴享受優先分配</p>
            </div>
          </div>
        </div><!--end col-->

        <div class="col-lg-3 col-md-6 mt-4 pt-2">
          <div class="card border-0 text-center features feature-clean course-feature p-4 shadow h-100">
            <div class="icons text-center">
              <i class="uil uil-award h1 text-primary"></i>
            </div>
            <div class="content mt-4">
              <h5>品牌授權</h5>
              <p class="text-muted mt-2">官方夥伴證書、Logo 使用權和聯合營銷機會</p>
            </div>
          </div>
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
  <!-- Partner Support End -->

  <!-- CTA Section Start -->
  <section class="section bg-light">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 text-center">
          <h4 class="title mb-4">準備好成為合作伙伴了嗎?</h4>
          <p class="text-muted para-desc mx-auto mb-4">
            加入日益壯大的 NocoBase 技術夥伴生態。無論您是系統集成商、諮詢公司還是技術服務商，這裡都有您的一席之地。
          </p>
        </div><!--end col-->
      </div><!--end row-->
      <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
          <div class="card border-0 shadow rounded overflow-hidden">
            <iframe
              src="https://service-cn.nocobase.com/public-forms/kn6r0dh1tu1"
              style="width: 100%; min-height: 700px; border: none;"
              loading="lazy"
            ></iframe>
          </div>
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
  <!-- CTA Section End -->

  <ShapeFooter />
</BaseTW>
