---
import PageHeader from "../../components/PageHeader.astro";
import Layout from "../../layouts/Layout.astro";

const title = "定價";
const description = "我們持續增強 NocoBase 的核心能力並保持開源，同時也在不斷開發更多開源且免費的外掛。對大多數中小企業與團隊來說，免費的社群版已足以滿足需求。當您的業務對進階功能、安全性、技術架構與技術支援有更高要求時，可以選擇商業版。";
const keywords = "NocoBase, 定價, 商業版, 社群版, 企業版";
---

<Layout title={title} description={description} keywords={keywords}>
  <PageHeader title={title} description={description} />
  <!-- Which Edition Start -->
  <section class="section pb-0" id="experience">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 text-center">
          <div class="section-title mb-4 pb-2">
            <div class="position-relative">
              <h4 class="title ">選擇哪個版本</h4>
            </div>
          </div>
        </div><!--end col-->
      </div><!--end row-->

      <div class="row">
        <div class="col-12 pt-2">
          <div class="timeline-page position-relative">
            <div class="timeline-item">
              <div class="row">
                <div class="col-lg-6 col-md-6 col-sm-6">
                  <div class="duration date-label-left position-relative text-md-end">
                    <h5>社區版，免費</h5>
                    <small class="text-muted mb-0">大多數用戶的選擇</small>
                  </div>
                </div><!--end col-->
                <div class="col-lg-6 col-md-6 col-sm-6 mt-4 mt-sm-0">
                  <div class="event event-description-right float-left text-start">
                    <h6 class="title mb-1 text-capitalize">當你需要</h6>
                    <ul class="text-muted">
                      <li>一個 AI 驅動的無代碼開發平臺作為團隊的基礎設施，開發業務系統和內部工具</li>
                      <li>使用熟悉的 Coding Agent 進行 AI 搭建</li>
                      <li>或使用所見即所得界面進行人工無代碼搭建，或兩者結合的方式進行協同搭建</li>
                      <li>擁有全部源代碼，私有部署，完全掌控</li>
                      <li>具備完整、豐富的能力，可以滿足大部分需求</li>
                      <li>具備絕大部分的 AI 員工功能</li>
                      <li>不要被這個平臺綁架，希望自由地擴展它的功能，滿足個性化需求</li>
                      <li>可以用它開發無限數量的應用，也不受用戶數、數據量的限制</li>
                      <li>可以接受在界面上不起眼的地方顯示 NocoBase 的標識</li>
                      <li>通過 NocoBase 社區獲得技術支持</li>
                    </ul>
                  </div>
                </div><!--end col-->
              </div><!--end row-->
            </div><!--end timeline item-->

            <div class="timeline-item mt-5 pt-2">
              <div class="row">
                <div class="col-lg-6 col-md-6 col-sm-6">
                  <div class="duration date-label-left position-relative text-md-end">
                    <h5>標準版，￥5,000</h5>
                    <small class="text-muted mb-0">常規用途的最佳選擇</small>
                  </div>
                </div><!--end col-->
                <div class="col-lg-6 col-md-6 col-sm-6 mt-4 mt-sm-0">
                  <div class="event event-description-right float-left text-start">
                    <h6 class="title mb-1 text-capitalize">當你還需要</h6>
                    <ul class="text-muted">
                      <li>將界面上的 NocoBase 標識換成自己的品牌信息</li>
                      <li>將其他系統的 MySQL、PostgreSQL 等數據庫接入 NocoBase 作為數據源</li>
                      <li>使用 Excel 導入或導出大量數據</li>
                      <li>一次性付費，可以終身使用</li>
                    </ul>
                  </div>
                </div><!--end col-->
              </div><!--end row-->
            </div><!--end timeline item-->

            <div class="timeline-item mt-5 pt-2">
              <div class="row">
                <div class="col-lg-6 col-md-6 col-sm-6">
                  <div class="duration date-label-left position-relative text-md-end">
                    <h5>專業版，￥50,000</h5>
                    <small class="text-muted mb-0">滿足專業團隊的需求</small>
                  </div>
                </div><!--end col-->
                <div class="col-lg-6 col-md-6 col-sm-6 mt-4 mt-sm-0">
                  <div class="event event-description-right float-left text-start">
                    <h6 class="title mb-1 text-capitalize">當你還需要</h6>
                    <ul class="text-muted">
                      <li>使用 NocoBase 為客戶開發上層應用</li>
                      <li>賦予 AI 員工高階能力</li>
                      <li>單點登錄</li>
                      <li>審批、子流程、Webhook 等高級工作流功能</li>
                      <li>在安全性方面有更出色的表現</li>
                      <li>記錄並展示每條數據的編輯歷史</li>
                      <li>定時自動備份數據</li>
                      <li>支持國產數據庫和環境</li>
                      <li>在開發流程方面有更高要求，有開發、測試、生產等多個環境</li>
                      <li>NocoBase 團隊的專屬使用諮詢</li>
                    </ul>
                  </div>
                </div><!--end col-->
              </div><!--end row-->
            </div><!--end timeline item-->

            <div class="timeline-item mt-5 pt-2">
              <div class="row">
                <div class="col-lg-6 col-md-6 col-sm-6">
                  <div class="duration date-label-left position-relative text-md-end">
                    <h5>企業版，聯繫我們</h5>
                    <small class="text-muted mb-0">滿足大型應用和企業的需求</small>
                  </div>
                </div><!--end col-->
                <div class="col-lg-6 col-md-6 col-sm-6 mt-4 mt-sm-0">
                  <div class="event event-description-right float-left text-start">
                    <h6 class="title mb-1 text-capitalize">當你還需要</h6>
                    <ul class="text-muted">
                      <li>集群部署 NocoBase 應用</li>
                      <li>詳細記錄每個用戶的每個操作以用作審計</li>
                      <li>將其他系統的 Oracle、Clickhouse、Doris 等數據庫接入 NocoBase 作為數據源</li>
                      <li>使用 多應用 架構部署和管理多個應用，可實現多租戶的用法</li>
                      <li>使用 多空間 功能部署和管理多個空間，可實現多門店、多工廠的用法</li>
                      <li>對遙測有專業要求，包括日誌、監控指標、鏈路追蹤</li>
                      <li>賦予 AI 員工高階能力</li>
                      <li>接入 Gmail、Outlook 等郵箱服務，使用手寫簽名審批等功能</li>
                      <li>獲取商業版本的全部源代碼</li>
                      <li>NocoBase 團隊在路線圖中優先安排你所需的功能</li>
                      <li>NocoBase 團隊用更快的響應速度提供更長時間的專屬支持</li>
                      <li>NocoBase 團隊為你提供專屬的擴展開發方案，包括插件、第三方集成等</li>
                    </ul>
                  </div>
                </div><!--end col-->
              </div><!--end row-->
            </div><!--end timeline item-->


          </div><!--end timeline page-->
          <!-- TIMELINE END -->
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
