---
import PageHeader from "../../../components/PageHeader.astro";
import Layout from "../../../layouts/Layout.astro";

const title = "Nhan vien AI";
const description = "Kham pha cach nhan vien AI cua NocoBase lam viec ngay trong he thong kinh doanh va thuc thi cong viec voi dung ngu canh.";
const keywords = "NocoBase, nhan vien AI, AI doanh nghiep, tu dong hoa, agent";
---

<Layout title={title} description={description} keywords={keywords}>
  <PageHeader title={title}>
    <span slot="description">{description}</span>
  </PageHeader>
  <section class="section"><div class="container"><div class="row align-items-top "><div class="col-lg-5 col-md-5"><div class="section-title"><h5 class="mb-4">Nhan vien AI lam viec <span class="text-primary">cung ban</span></h5><p class="text-muted">Trong NocoBase, nhan vien AI khong chi la chatbot hay agent tach biet. Ho duoc tich hop truc tiep vao he thong kinh doanh, hieu ngu canh van hanh va co the thuc hien cong viec ngay ben trong quy trinh that.</p></div></div><div class="col-lg-7"><div class="card rounded border-0 shadow ms-lg-5"><video controls class="rounded shadow"><source src="https://static-docs.nocobase.com/AE-3.1-EN.mp4" type="video/mp4"></video></div></div></div></div></section>
</Layout>
