---
import PageHeader from "../../../components/PageHeader.astro";
import Layout from "../../../layouts/Layout.astro";

const title = "Block va hanh dong";
const description = "Tim hieu cach NocoBase tach giao dien va du lieu de ket hop block, hanh dong va luong su kien mot cach linh hoat.";
const keywords = "NocoBase, block, hanh dong, event flow, giao dien, no-code";
---

<Layout title={title} description={description} keywords={keywords}>
  <PageHeader title={title}>
    <span slot="description">{description}</span>
  </PageHeader>
  <section class="section"><div class="container">
    <div class="row align-items-top "><div class="col-lg-5 col-md-5"><div class="section-title"><h5 class="mb-4">Tach <span class="text-primary">giao dien va du lieu</span> de ket hop block va hanh dong tu do</h5><p class="text-muted">Khac voi nhieu san pham no-code bat dau tu bo cuc trang, NocoBase duoc thiet ke xoay quanh du lieu. Cau truc du lieu duoc xac dinh truoc, sau do moi xay giao dien. Nhờ vay, cung mot tap du lieu co the phuc vu nhieu kieu trai nghiem va thao tac khac nhau.</p></div></div><div class="col-lg-7"><div class="card rounded border-0 shadow ms-lg-5"><video controls class="rounded shadow"><source src="https://static-docs.nocobase.com/BA-2.1-EN.mp4" type="video/mp4"></video></div></div></div>
    <div class="row align-items-top mt-100"><div class="col-lg-5 col-md-5"><div class="section-title"><h5 class="mb-4">Mot <span class="text-primary">block bo loc</span> cho nhieu block du lieu va luong su kien</h5><p class="text-muted">Khi mot trang co nhieu block du lieu nhu bang va bieu do, mot block bo loc duy nhat co the dieu khien tat ca cung luc.</p></div></div><div class="col-lg-7"><div class="card rounded border-0 shadow ms-lg-5"><video controls class="rounded shadow"><source src="https://static-docs.nocobase.com/BA-2.2-EN.mp4" type="video/mp4"></video></div></div></div>
    <div class="row align-items-top mt-100"><div class="col-lg-5 col-md-5"><div class="section-title"><h5 class="mb-4">Dung <span class="text-primary">luong su kien</span> de ket noi block va hanh dong</h5><p class="text-muted">Khi mot trang gom nhieu block va hanh dong, luong su kien giup dieu phoi logic tuong tac giua chung. Vi du, khi mo mot khach hang trong CRM, ban co the dong thoi xem cac don hang lien quan tu ERP.</p></div></div><div class="col-lg-7"><div class="card rounded border-0 shadow ms-lg-5"><video controls class="rounded shadow"><source src="https://static-docs.nocobase.com/BA-2.3-EN.mp4" type="video/mp4"></video></div></div></div>
  </div></section>
</Layout>
