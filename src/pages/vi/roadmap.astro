---
import PageHeader from "../../components/PageHeader.astro";
import Layout from "../../layouts/Layout.astro";

const title = "Lo trinh";
const description = "Theo doi lo trinh phat trien cua NocoBase va xem nhung hang muc da hoan thanh cung nhu dang duoc thuc hien.";
const keywords = "NocoBase, lo trinh, san pham, tinh nang, phat trien";
---

<Layout title={title} description={description} keywords={keywords}>
  <PageHeader title={title} description={description}>
  </PageHeader>

  <section class="section">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-9">
          <div class="card shadow border-0 rounded">
            <div class="card-body roadmap-body">
              <div class="roadmap-legend">
                <span class="legend-item">
                  <i class="uil uil-check-circle legend-icon legend-icon-done"></i>
                  <span>Da hoan thanh</span>
                </span>
                <span class="legend-item">
                  <i class="uil uil-clock-three legend-icon legend-icon-progress"></i>
                  <span>Dang thuc hien</span>
                </span>
              </div>

              <ul class="roadmap-list">
                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Nang cap nhan vien AI</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Giao dien mo rong AI cap kernel</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Ho tro tich hop MCP</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Workflow: node nhan vien AI</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Ho tro sub-agent</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Ho tro sandbox va skill tuy chinh</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Ho tro da agent chay song song</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">NocoBase MCP & CLI & Skills</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Xay dung ung dung NocoBase hoan chinh voi cac agent lap trinh cuc bo nhu Claude Code, Codex va OpenCode</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Ket noi cac agent cuc bo nhu OpenClaw voi NocoBase cho luong nghiep vu</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Vong doi AI day du cho xay dung cuc bo, xac thuc va debug tu dong</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>AI Worktree</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">IdP: OAuth</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Tuong thich voi OAuth 2.1 va OpenID Connect</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Cho phep NocoBase dong vai tro nha cung cap danh tinh de dang nhap vao cac he thong khac</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Nhanh moi /v2/</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span><code>@nocobase/app</code> cung cap client-v2</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Goi core <code>@nocobase/client-v2</code></span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Moi plugin deu co thu muc <code>/src/client-v2</code></span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Tuyen duong moi <code>/v2/</code></span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-progress">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-clock-three align-middle"></i>
                      <span class="roadmap-title">Quan ly migration cho merge va phat hanh tren nhieu moi truong</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">He thong build dua tren Rsbuild</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span><code>yarn dev</code> va <code>yarn dev:umi</code></span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Tai plugin theo nhu cau</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Cai thien dang ke toc do tai ban dau cua ung dung NocoBase</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Ho tro JS Item Action</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Cung cap nhieu loai action khac nhau</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Custom Request 2.0</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Cac action custom request</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Custom request trong cac buoc workflow dua tren event-stream</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-progress">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-clock-three align-middle"></i>
                      <span class="roadmap-title">NocoBase Embed 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-progress">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-clock-three align-middle"></i>
                      <span class="roadmap-title">Bien tuy chinh</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-done">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-check-circle align-middle"></i>
                      <span class="roadmap-title">Tree block 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-done">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-check-circle align-middle"></i>
                      <span class="roadmap-title">Calendar block 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-done">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-check-circle align-middle"></i>
                      <span class="roadmap-title">Kanban block 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Chuyen doi toan bo plugin sang client-v2</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Moi plugin cung cap va cai tien <code>/src/client-v2</code></span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">UI Layout</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Tao cac layout linh hoat vuot qua gioi han cua desktop va mobile</span></li>
                  </ul>
                </li>
              </ul>
            </div>
          </div>
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
</Layout>

<style>
  .roadmap-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.25rem;
    padding: 0.85rem 1rem;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, #f8fbff 0%, #f5f7fb 100%);
    border: 1px solid #e9eef5;
  }

  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: #475569;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .legend-icon {
    font-size: 1rem;
  }

  .legend-icon-done {
    color: #16a34a;
  }

  .legend-icon-progress {
    color: #f59e0b;
  }

  .roadmap-list,
  .roadmap-list ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .roadmap-list > li {
    padding: 1rem 0 1.15rem;
    border-bottom: 1px solid #edf2f7;
  }

  .roadmap-list > li:first-child {
    padding-top: 0;
  }

  .roadmap-list > li:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .roadmap-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.55rem;
  }

  .roadmap-title {
    font-weight: 700;
    color: #0f172a;
  }

  .roadmap-item-status {
    margin-bottom: 0;
  }

  .roadmap-title-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .roadmap-list ul {
    margin-top: 0.25rem;
    padding-left: 1.5rem;
  }

  .roadmap-list ul li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    color: #475569;
    padding: 0.28rem 0;
    line-height: 1.65;
  }

  .roadmap-list ul li i,
  .roadmap-title-wrap i {
    margin-top: 0.2rem;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .status-done i {
    color: #16a34a;
  }

  .status-progress i {
    color: #f59e0b;
  }

  .roadmap-body code {
    background: #f1f5f9;
    color: #334155;
    border-radius: 0.35rem;
    padding: 0.12rem 0.4rem;
    font-size: 0.92em;
  }
</style>
