---
import PageHeader from "../../components/PageHeader.astro";
import Layout from "../../layouts/Layout.astro";
import { getPage } from "../../utils";

const page = await getPage("agreement", "en");

const title = "Thoa thuan cap phep";
const description = "Xem thoa thuan cap phep cua NocoBase. Noi dung phap ly duoc giu nguyen bang tieng Anh.";
const keywords = "NocoBase, thoa thuan cap phep, giay phep, dieu khoan phap ly";
---

<Layout title={title} description={description} keywords={keywords}>
  <PageHeader title={title} description={description} />

  <section class="section">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-9">
          <div class="card shadow border-0 rounded">
            <div class="card-body license-body">
              <div set:html={page.content}></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
