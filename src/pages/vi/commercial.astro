---
import PageHeader from "../../components/PageHeader.astro";
import Layout from "../../layouts/Layout.astro";

const title = "Bang gia";
const description = "Chung toi lien tuc nang cao cac nang luc cot loi cua NocoBase va van giu nen tang nay o dang open source, dong thoi tiep tuc phat trien them nhieu plugin open source va mien phi. Phan lon doanh nghiep nho va cac doi ngu co the dap ung nhu cau bang Community Edition mien phi. Khi doanh nghiep cua ban co yeu cau cao hon ve tinh nang nang cao, bao mat, kien truc ky thuat va ho tro ky thuat, ban co the chon Commercial Edition.";
const keywords = "NocoBase, bang gia, giay phep, phien ban community, phien ban standard, phien ban professional, phien ban enterprise";
---

<Layout title={title} description={description} keywords={keywords}>
  <PageHeader title={title} description={description} />
  <!-- Which Edition Start -->
  <section class="section pb-0" id="experience">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 text-center">
          <div class="section-title mb-4 pb-2">
            <div class="position-relative">
              <h4 class="title mb-4">Nen chon phien ban nao</h4>
            </div>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="col-12 pt-2">
          <div class="timeline-page position-relative">
            <div class="timeline-item">
              <div class="row">
                <div class="col-lg-6 col-md-6 col-sm-6">
                  <div class="duration date-label-left position-relative text-md-end">
                    <h5>Phien ban Community, mien phi</h5>
                    <small class="text-muted mb-0">Lua chon cua da so nguoi dung</small>
                  </div>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 mt-4 mt-sm-0">
                  <div class="event event-description-right float-left text-start">
                    <h6 class="title mb-1 text-capitalize">Khi ban can</h6>
                    <ul class="text-muted">
                      <li>Mot nen tang no-code duoc van hanh boi AI, dong vai tro ha tang cho doi ngu cua ban khi xay dung he thong nghiep vu va cong cu noi bo</li>
                      <li>Su dung cac coding agent quen thuoc de xay dung voi su ho tro cua AI</li>
                      <li>Hoac tu xay dung bang giao dien no-code WYSIWYG, hoac ket hop ca hai cach lam</li>
                      <li>Ma nguon day du, tu luu tru va toan quyen kiem soat</li>
                      <li>Tinh nang phong phu va day dan de dap ung phan lon nhu cau</li>
                      <li>Da bao gom phan lon nang luc cua nhan vien AI</li>
                      <li>Tu do mo rong ma khong bi lock-in, de dap ung cac nhu cau tuy bien</li>
                      <li>Xay dung ung dung khong gioi han, khong gioi han nguoi dung hay du lieu</li>
                      <li>Chap nhan logo NocoBase hien thi nhe tren giao dien</li>
                      <li>Ho tro ky thuat tu cong dong NocoBase</li>
                    </ul>
                  </div>
                </div><!--end col-->
              </div><!--end row-->
            </div><!--end timeline item-->

            <div class="timeline-item mt-5 pt-2">
              <div class="row">
                <div class="col-lg-6 col-md-6 col-sm-6">
                  <div class="duration date-label-left position-relative text-md-end">
                    <h5>Phien ban Standard, $800</h5>
                    <small class="text-muted mb-0">Lua chon phu hop cho nhu cau su dung thuong xuyen</small>
                  </div>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 mt-4 mt-sm-0">
                  <div class="event event-description-right float-left text-start">
                    <h6 class="title mb-1 text-capitalize">Khi ban cung can</h6>
                    <ul class="text-muted">
                      <li>Thay the nhan dien NocoBase tren giao dien bang thuong hieu cua rieng ban</li>
                      <li>Ket noi co so du lieu ben ngoai nhu MySQL va PostgreSQL lam nguon du lieu cho NocoBase</li>
                      <li>Nhap va xuat khoi luong lon du lieu bang Excel</li>
                      <li>Thanh toan mot lan de su dung lau dai</li>
                    </ul>
                  </div>
                </div><!--end col-->
              </div><!--end row-->
            </div><!--end timeline item-->

            <div class="timeline-item mt-5 pt-2">
              <div class="row">
                <div class="col-lg-6 col-md-6 col-sm-6">
                  <div class="duration date-label-left position-relative text-md-end">
                    <h5>Phien ban Professional, $8,000</h5>
                    <small class="text-muted mb-0">Phu hop cho doi ngu chuyen nghiep</small>
                  </div>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 mt-4 mt-sm-0">
                  <div class="event event-description-right float-left text-start">
                    <h6 class="title mb-1 text-capitalize">Khi ban cung can</h6>
                    <ul class="text-muted">
                      <li>Xay dung ung dung cho khach hang cua ban bang NocoBase</li>
                      <li>Trao cho nhan vien AI cac nang luc nang cao</li>
                      <li>Single sign-on (SSO)</li>
                      <li>Tinh nang workflow nang cao nhu phe duyet, subflow va webhook</li>
                      <li>Kha nang bao mat manh hon</li>
                      <li>Ghi lai va hien thi day du lich su chinh sua cua tung ban ghi</li>
                      <li>Sao luu du lieu tu dong theo lich</li>
                      <li>Yeu cau cao hon cho quy trinh phat trien voi moi truong development, testing va production</li>
                      <li>Tu van su dung rieng tu doi ngu NocoBase</li>
                    </ul>
                  </div>
                </div><!--end col-->
              </div><!--end row-->
            </div><!--end timeline item-->

            <div class="timeline-item mt-5 pt-2">
              <div class="row">
                <div class="col-lg-6 col-md-6 col-sm-6">
                  <div class="duration date-label-left position-relative text-md-end">
                    <h5>Phien ban Enterprise, lien he chung toi</h5>
                    <small class="text-muted mb-0">Phu hop cho ung dung quy mo lon va moi truong doanh nghiep</small>
                  </div>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 mt-4 mt-sm-0">
                  <div class="event event-description-right float-left text-start">
                    <h6 class="title mb-1 text-capitalize">Khi ban cung can</h6>
                    <ul class="text-muted">
                      <li>Trien khai theo cum cho ung dung NocoBase</li>
                      <li>Ghi log chi tiet moi hanh dong cua nguoi dung de phuc vu kiem toan</li>
                      <li>Ket noi cac nguon du lieu ben ngoai nhu Oracle, ClickHouse va Doris voi NocoBase</li>
                      <li>Su dung kien truc da ung dung de trien khai va quan ly nhieu ung dung trong cac kich ban multi-tenant</li>
                      <li>Su dung tinh nang multi-space de trien khai va quan ly nhieu khong gian trong cac kich ban da cua hang hoac da nha may</li>
                      <li>Nhu cau telemetry chuyen nghiep, bao gom log, chi so giam sat va tracing</li>
                      <li>Tich hop Gmail, Outlook va cac dich vu email khac, dong thoi su dung tinh nang nhu phe duyet chu ky viet tay</li>
                      <li>Trao cho nhan vien AI cac nang luc nang cao</li>
                      <li>Truy cap day du ma nguon cua phien ban thuong mai</li>
                      <li>Duoc uu tien tren roadmap NocoBase cho nhung tinh nang ban can</li>
                      <li>Phan hoi nhanh hon va thoi gian ho tro rieng dai hon tu doi ngu NocoBase</li>
                      <li>Giai phap phat trien mo rong rieng tu doi ngu NocoBase, bao gom plugin va tich hop ben thu ba</li>
                    </ul>
                  </div>
                </div><!--end col-->
              </div><!--end row-->
            </div><!--end timeline item-->


          </div><!--end timeline page-->
          <!-- TIMELINE END -->
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
