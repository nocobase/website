---
import PageHeader from "../../components/PageHeader.astro";
import Layout from "../../layouts/Layout.astro";

const title = "Roadmap";
const description = "Acompanhe o roadmap da NocoBase e veja o que ja foi concluido e o que esta em andamento.";
const keywords = "NocoBase, roadmap, produto, funcionalidades, desenvolvimento";
---

<Layout title={title} description={description} keywords={keywords}>
  <PageHeader title={title} description={description}>
  </PageHeader>

  <section class="section">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-9">
          <div class="card shadow border-0 rounded">
            <div class="card-body roadmap-body">
              <div class="roadmap-legend">
                <span class="legend-item">
                  <i class="uil uil-check-circle legend-icon legend-icon-done"></i>
                  <span>Concluido</span>
                </span>
                <span class="legend-item">
                  <i class="uil uil-clock-three legend-icon legend-icon-progress"></i>
                  <span>Em andamento</span>
                </span>
              </div>

              <ul class="roadmap-list">
                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Melhorias nos funcionarios de IA</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Interface de extensao de IA no nivel do kernel</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Suporte para integracao com MCP</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Workflow: no de funcionario de IA</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Suporte para subagentes</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Suporte para sandbox e skills personalizadas</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Suporte multiagente em paralelo</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">NocoBase MCP & CLI & Skills</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Criar aplicacoes completas da NocoBase com agentes locais de codigo como Claude Code, Codex e OpenCode</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Conectar agentes locais como OpenClaw a NocoBase para fluxos de negocio</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Ciclo completo de IA para construcao local, validacao e depuracao automatica</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>AI Worktree</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">IdP: OAuth</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Compatibilidade com OAuth 2.1 e OpenID Connect</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Permitir que a NocoBase atue como provedor de identidade para login em outros sistemas</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Nova branch /v2/</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span><code>@nocobase/app</code> fornece client-v2</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Pacote core <code>@nocobase/client-v2</code></span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Cada plugin inclui um diretorio <code>/src/client-v2</code></span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Nova rota <code>/v2/</code></span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-progress">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-clock-three align-middle"></i>
                      <span class="roadmap-title">Gestao de migracoes para merge e publicacao em varios ambientes</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Sistema de build baseado em Rsbuild</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span><code>yarn dev</code> e <code>yarn dev:umi</code></span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Carregamento tardio de plugins</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Melhoria significativa na velocidade de carregamento inicial das aplicacoes NocoBase</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Suporte para JS Item Action</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Oferecer diferentes tipos de action</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Solicitacao personalizada 2.0</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Acoes de solicitacao personalizada</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Solicitacoes personalizadas em etapas de workflow baseadas em event-stream</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-progress">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-clock-three align-middle"></i>
                      <span class="roadmap-title">NocoBase Embed 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-progress">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-clock-three align-middle"></i>
                      <span class="roadmap-title">Variaveis personalizadas</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-done">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-check-circle align-middle"></i>
                      <span class="roadmap-title">Bloco de arvore 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-done">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-check-circle align-middle"></i>
                      <span class="roadmap-title">Bloco de calendario 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-done">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-check-circle align-middle"></i>
                      <span class="roadmap-title">Bloco kanban 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Migracao completa dos plugins para client-v2</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Cada plugin fornece e aprimora <code>/src/client-v2</code></span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">UI Layout</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Criar layouts flexiveis que vao alem das limitacoes de desktop e mobile</span></li>
                  </ul>
                </li>
              </ul>
            </div>
          </div>
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
</Layout>

<style>
  .roadmap-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.25rem;
    padding: 0.85rem 1rem;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, #f8fbff 0%, #f5f7fb 100%);
    border: 1px solid #e9eef5;
  }

  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: #475569;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .legend-icon {
    font-size: 1rem;
  }

  .legend-icon-done {
    color: #16a34a;
  }

  .legend-icon-progress {
    color: #f59e0b;
  }

  .roadmap-list,
  .roadmap-list ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .roadmap-list > li {
    padding: 1rem 0 1.15rem;
    border-bottom: 1px solid #edf2f7;
  }

  .roadmap-list > li:first-child {
    padding-top: 0;
  }

  .roadmap-list > li:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .roadmap-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.55rem;
  }

  .roadmap-title {
    font-weight: 700;
    color: #0f172a;
  }

  .roadmap-item-status {
    margin-bottom: 0;
  }

  .roadmap-title-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .roadmap-list ul {
    margin-top: 0.25rem;
    padding-left: 1.5rem;
  }

  .roadmap-list ul li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    color: #475569;
    padding: 0.28rem 0;
    line-height: 1.65;
  }

  .roadmap-list ul li i,
  .roadmap-title-wrap i {
    margin-top: 0.2rem;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .status-done i {
    color: #16a34a;
  }

  .status-progress i {
    color: #f59e0b;
  }

  .roadmap-body code {
    background: #f1f5f9;
    color: #334155;
    border-radius: 0.35rem;
    padding: 0.12rem 0.4rem;
    font-size: 0.92em;
  }
</style>
