---
import BaseEN from "../../../layouts/BaseEN.astro";
import ShapeFooter from "../../../components/ShapeFooter.astro";

// Solutions library — to add a new solution, just append an entry here
const solutions = [
  {
    title: "All-in-One Business Suite",
    desc: "CRM, sales, ticketing, projects, fixed assets and HR — six modules unified in one system, with built-in AI employees and workflows.",
    href: "/en/solutions/all-in-one",
    cover: "https://static-docs.nocobase.com/all-in-one-cover-2026-05-20.jpg",
    icon: "uil-layer-group",
    categories: ["All-in-One"],
    status: "Updating",
    tags: ["All-in-One", "Multi business line", "AI employees"],
  },
  {
    title: "CRM",
    desc: "Lead management, follow-up, conversion, merge/dedupe and a customer 360 view — a ready-to-use CRM module.",
    href: "/en/solutions/all-in-one/crm",
    cover: "https://static-docs.nocobase.com/module-crm-cover-260521.jpg",
    icon: "uil-users-alt",
    categories: ["All-in-One", "Customers & Sales"],
    status: "All-in-One module",
    tags: ["CRM", "Follow-ups", "Customer 360"],
  },
  {
    title: "Order Management",
    desc: "Quotes, sales orders, invoices and payments end to end, with approval workflow, multi-currency, AR KPIs and overdue analysis.",
    href: "/en/solutions/all-in-one/sales",
    cover: "https://static-docs.nocobase.com/module-order-cover-260527.jpg",
    icon: "uil-bill",
    categories: ["All-in-One", "Customers & Sales"],
    status: "All-in-One module",
    tags: ["Orders", "Quotes", "Receivables"],
  },
  {
    title: "Help Desk",
    desc: "Customer issue reporting, smart dispatch, SLA timing, priority, AI classification, satisfaction reviews and a service workbench.",
    href: "/en/solutions/all-in-one/ticketing",
    cover: "https://static-docs.nocobase.com/module-tickets-cover-260521.jpg",
    icon: "uil-comment-alt-lines",
    categories: ["All-in-One", "Customer Service"],
    status: "All-in-One module",
    tags: ["Ticketing", "Support", "SLA"],
  },
  {
    title: "Project Management",
    desc: "Two-level project + task model with owners, progress, milestones, overdue alerts and workload distribution.",
    href: "/en/solutions/all-in-one/project",
    cover: "https://static-docs.nocobase.com/module-pm-cover-260521.jpg",
    icon: "uil-clipboard-notes",
    categories: ["All-in-One", "Projects & R&D"],
    status: "All-in-One module",
    tags: ["Projects", "Tasks", "Milestones"],
  },
  {
    title: "IT Asset Management",
    desc: "Procurement, assignment, maintenance and disposal — full lifecycle management for IT and office assets.",
    href: "/en/solutions/all-in-one/asset",
    cover: "https://static-docs.nocobase.com/module-assets-cover-260521.jpg",
    icon: "uil-desktop",
    categories: ["All-in-One"],
    status: "All-in-One module",
    tags: ["Assets", "Maintenance", "Procurement"],
  },
  {
    title: "HR Management",
    desc: "Employee records, onboarding, offboarding, leave, probation tracking and position / department structure.",
    href: "/en/solutions/all-in-one/hr",
    cover: "https://static-docs.nocobase.com/module-hr-cover-260521.jpg",
    icon: "uil-user-check",
    categories: ["All-in-One"],
    status: "All-in-One module",
    tags: ["HR", "Leave", "Org structure"],
  },
  {
    title: "CRM Plus",
    desc: "A complete sales loop from leads, follow-ups and conversion to Customer 360. Modular and decomposable, deeply integrated with AI employees, with built-in multi-currency and dashboards.",
