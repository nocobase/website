    cover: "https://static-docs.nocobase.com/design-2026-02-01-02-46-56-opt.jpg",
    icon: "uil-chart-growth",
    categories: ["Customers & Sales"],
    tags: ["CRM", "Sales management", "Customer 360"],
  },
  {
    title: "CRM Basic",
    desc: "A flexible, deeply customizable CRM foundation. Full data ownership, ready to extend and reshape on top of it.",
    href: "/en/solutions/crm",
    cover: "https://static-docs.nocobase.com/img_v3_02o3_58bedc3b-7f22-4b56-9c74-83463ffb186g32-opt.jpeg",
    icon: "uil-users-alt",
    categories: ["Customers & Sales"],
    tags: ["CRM", "Customizable", "Foundation"],
  },
  {
    title: "Smart Ticketing 2.0",
    desc: "The full lifecycle from customer report to case closure. A T-shaped data architecture supports multiple business scenarios, with AI employees assisting classification and handling.",
    href: "/en/solutions/ticketing-v2",
    cover: "https://static-docs.nocobase.com/ticketing-imgs-2026-01-01-00-46-12-opt.jpg",
    icon: "uil-robot",
    categories: ["Customer Service"],
    tags: ["Ticketing", "Support", "AI classification"],
  },
  {
    title: "Ticketing System (1.x)",
    desc: "An important complement to the CRM, providing full ticket lifecycle management — ideal for after-sales and customer service scenarios.",
    href: "/en/solutions/ticketing",
    cover: "https://static-docs.nocobase.com/img_v3_02o5_a2422688-f176-4c84-bf32-5ee0774f919g-1.png",
