  },
  {
    title: "Project Management (1.x)",
    desc: "Full project lifecycle management from requirements to delivery, covering tasks, iterations, progress, milestones and workload.",
    href: "/en/solutions/project-management",
    cover: "https://static-docs.nocobase.com/screenshot-20250909-151855-1.png",
