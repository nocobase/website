---
import PageHeader from "../../components/PageHeader.astro";
import Layout from "../../layouts/Layout.astro";
import { getPage } from "../../utils";

const page = await getPage("roadmap");
const title = page.title;
const description = page.description;
const keywords = page.keywords;
---

<Layout title={title} description={description} keywords={keywords}>
  <PageHeader title={title} description={description}>
  </PageHeader>

  <section class="section">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-9">
          <div class="card shadow border-0 rounded">
            <div class="card-body roadmap-body">
              <div class="roadmap-legend">
                <span class="legend-item">
                  <i class="uil uil-check-circle legend-icon legend-icon-done"></i>
                  <span>Done</span>
                </span>
                <span class="legend-item">
                  <i class="uil uil-clock-three legend-icon legend-icon-progress"></i>
                  <span>In Progress</span>
                </span>
              </div>

              <ul class="roadmap-list">
                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">AI Employee Enhancements</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Kernel-level AI extension interface</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>MCP integration support</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Workflow: AI employee node</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Sub-agent support</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Sandbox support and custom skills</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Parallel multi-agent support</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">NocoBase MCP & CLI & Skills</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Build complete NocoBase applications with local coding agents such as Claude Code, Codex, and OpenCode</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Connect local agents such as OpenClaw to NocoBase for business workflows</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Complete AI loop for local building, validation, and automated debugging</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>AI Worktree</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">IdP: OAuth</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Support for OAuth 2.1 and OpenID Connect</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Allow NocoBase to act as an identity provider for signing in to other systems</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">New /v2/ Branch</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span><code>@nocobase/app</code> provides client-v2</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Core package <code>@nocobase/client-v2</code></span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Each plugin provides a <code>/src/client-v2</code> directory</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>New <code>/v2/</code> route</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-progress">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-clock-three align-middle"></i>
                      <span class="roadmap-title">Migration Management for Multi-Environment Merge and Release</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Rsbuild-Based Build System</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span><code>yarn dev</code> and <code>yarn dev:umi</code></span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Lazy Loading for Plugins</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Significantly improve the first-load speed of NocoBase applications</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">JS Item Action Support</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Provide different action forms</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Custom Request 2.0</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Custom request actions</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Custom requests in event-stream workflow steps</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-progress">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-clock-three align-middle"></i>
                      <span class="roadmap-title">NocoBase Embed 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-progress">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-clock-three align-middle"></i>
                      <span class="roadmap-title">Custom Variables</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-done">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-check-circle align-middle"></i>
                      <span class="roadmap-title">Tree Block 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-done">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-check-circle align-middle"></i>
                      <span class="roadmap-title">Calendar Block 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-done">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-check-circle align-middle"></i>
                      <span class="roadmap-title">Kanban Block 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Full Plugin Migration to client-v2</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Each plugin provides and improves <code>/src/client-v2</code></span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">UI Layout</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Create flexible layouts beyond desktop and mobile constraints</span></li>
                  </ul>
                </li>
              </ul>
            </div>
          </div>
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
</Layout>

<style>
  .roadmap-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.25rem;
    padding: 0.85rem 1rem;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, #f8fbff 0%, #f5f7fb 100%);
    border: 1px solid #e9eef5;
  }

  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: #475569;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .legend-icon {
    font-size: 1rem;
  }

  .legend-icon-done {
    color: #16a34a;
  }

  .legend-icon-progress {
    color: #f59e0b;
  }

  .roadmap-list,
  .roadmap-list ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .roadmap-list > li {
    padding: 1rem 0 1.15rem;
    border-bottom: 1px solid #edf2f7;
  }

  .roadmap-list > li:first-child {
    padding-top: 0;
  }

  .roadmap-list > li:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .roadmap-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.55rem;
  }

  .roadmap-title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.5;
    color: #1e293b;
  }

  .roadmap-title-wrap {
    display: inline-flex;
    align-items: flex-start;
    gap: 0.65rem;
    min-width: 0;
  }

  .roadmap-item-status > .roadmap-title-wrap > i {
    margin-top: 0.18rem;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .roadmap-item-status.status-done > .roadmap-title-wrap > i {
    color: #16a34a;
  }

  .roadmap-item-status.status-progress > .roadmap-title-wrap > i {
    color: #f59e0b;
  }

  .roadmap-list ul {
    margin-top: 0.45rem;
    margin-left: 0.25rem;
    padding-left: 0.5rem;
    border-left: 2px solid #e9eef5;
  }

  .roadmap-list ul li {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    margin-top: 0.7rem;
    line-height: 1.7;
    color: #475569;
  }

  .roadmap-list ul li > i {
    margin-top: 0.2rem;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .roadmap-list ul li > span {
    flex: 1;
    min-width: 0;
  }

  .roadmap-list ul li.status-done > i {
    color: #16a34a;
  }

  .roadmap-list ul li.status-progress > i {
    color: #f59e0b;
  }

  .roadmap-body code {
    font-size: 0.875em;
    color: #e83e8c;
    background-color: #f8f9fa;
    padding: 0.15em 0.4em;
    border-radius: 3px;
  }

  @media (max-width: 576px) {
    .roadmap-item {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.4rem;
    }
  }
</style>
