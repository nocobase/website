---
import BaseID from "../../../layouts/BaseID.astro";
import ShapeFooter from "../../../components/ShapeFooter.astro";

// Pustaka solusi — untuk menambah solusi baru, cukup tambahkan satu entri di sini
const solutions = [
  {
    title: "Suite Bisnis All-in-One",
    desc: "Enam modul — CRM, penjualan, tiket, proyek, aset tetap, dan SDM — terintegrasi dalam satu sistem, dilengkapi karyawan AI dan workflow bawaan.",
    href: "/id/solutions/all-in-one",
    cover: "https://static-docs.nocobase.com/all-in-one-cover-2026-05-20.jpg",
    icon: "uil-layer-group",
    categories: ["All-in-One"],
    status: "Sedang diperbarui",
    tags: ["All-in-One", "Multi-lini bisnis", "Karyawan AI"],
  },
  {
    title: "CRM Plus",
    desc: "Siklus penjualan lengkap dari prospek, tindak lanjut, konversi, hingga pelanggan 360. Modul dapat dipecah, terintegrasi mendalam dengan karyawan AI, dilengkapi multi-mata uang dan dasbor.",
    href: "/id/solutions/crm-v2",
    cover: "https://static-docs.nocobase.com/design-2026-02-01-02-46-56-opt.jpg",
    icon: "uil-chart-growth",
    categories: ["Pelanggan & Penjualan"],
    tags: ["CRM", "Manajemen penjualan", "Pelanggan 360"],
  },
  {
    title: "CRM Dasar",
    desc: "Kerangka dasar CRM yang fleksibel dan dapat dikustomisasi secara mendalam, dengan kedaulatan data penuh, dan dapat diperluas serta dimodifikasi di atasnya.",
    href: "/id/solutions/crm",
    cover: "https://static-docs.nocobase.com/img_v3_02o3_58bedc3b-7f22-4b56-9c74-83463ffb186g32-opt.jpeg",
    icon: "uil-users-alt",
    categories: ["Pelanggan & Penjualan"],
    tags: ["CRM", "Dapat dikustomisasi", "Fondasi"],
  },
  {
    title: "Sistem Tiket Cerdas 2.0",
    desc: "Siklus hidup lengkap dari laporan masalah pelanggan hingga penutupan kasus. Arsitektur data tipe-T mendukung berbagai skenario bisnis, dengan karyawan AI yang membantu klasifikasi dan penanganan.",
    href: "/id/solutions/ticketing-v2",
    cover: "https://static-docs.nocobase.com/ticketing-imgs-2026-01-01-00-46-12-opt.jpg",
    icon: "uil-robot",
    categories: ["Layanan Pelanggan"],
    tags: ["Tiket", "Layanan pelanggan", "Klasifikasi AI"],
  },
  {
    title: "Sistem Tiket (1.x)",
    desc: "Sebagai pelengkap penting CRM, menyediakan manajemen siklus hidup tiket yang lengkap, cocok untuk skenario purnajual dan layanan pelanggan.",
    href: "/id/solutions/ticketing",
    cover: "https://static-docs.nocobase.com/img_v3_02o5_a2422688-f176-4c84-bf32-5ee0774f919g-1.png",
    icon: "uil-comment-alt-lines",
    categories: ["Layanan Pelanggan"],
    tags: ["Tiket", "Purnajual", "1.x"],
  },
  {
    title: "Manajemen Proyek (1.x)",
    desc: "Manajemen siklus hidup proyek penuh dari kebutuhan hingga pengiriman, mencakup tugas, iterasi, progres, tonggak pencapaian, dan beban kerja.",
    href: "/id/solutions/project-management",
    cover: "https://static-docs.nocobase.com/screenshot-20250909-151855-1.png",
    icon: "uil-clipboard-notes",
    categories: ["Proyek & Litbang"],
    tags: ["Proyek", "Kolaborasi litbang", "Tonggak pencapaian", "1.x"],
  },
];

// Kategori filter (urutan adalah urutan tampilan)
const categories = ["Semua", "All-in-One", "Pelanggan & Penjualan", "Layanan Pelanggan", "Proyek & Litbang"];
---

<BaseID
  title="Solusi lainnya - Pustaka Solusi NocoBase"
  description="Pustaka Solusi NocoBase: suite bisnis all-in-one, serta solusi bisnis mandiri seperti CRM, penjualan, tiket, dan manajemen proyek, difilter per skenario, semuanya berbasis platform tanpa kode NocoBase, siap pakai dan dapat di-host sendiri."
  keywords="solusi NocoBase, pustaka solusi, suite bisnis all-in-one, sistem CRM, sistem tiket, sistem manajemen proyek, solusi tanpa kode, sistem bisnis open source"
>
  <!-- Hero Start -->
  <section class="bg-half-170 bg-light d-table w-100">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 text-center">
          <div class="title-heading">
            <h1 class="title fw-bold mb-3">Pustaka Solusi</h1>
            <p class="para-desc mx-auto text-muted mb-0">
              Solusi bisnis yang dibangun di atas platform tanpa kode NocoBase. Pilih yang sesuai dengan skenario Anda. Semua siap pakai dan mendukung host sendiri, dengan solusi baru yang terus hadir.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- Hero End -->

  <!-- Solutions Gallery Start -->
  <section class="section">
    <div class="container">
      <!-- 筛选 chips -->
      <div class="row justify-content-center">
        <div class="col-12 text-center mb-4">
          <ul class="solution-filter list-unstyled mb-0" id="solution-filter">
            {categories.map((cat, i) => (
              <li
                class:list={["filter-chip", { active: i === 0 }]}
                data-filter={cat === "Semua" ? "*" : cat}
              >{cat}</li>
            ))}
          </ul>
        </div>
      </div>

      <!-- 卡片网格 -->
      <div class="row" id="solution-grid">
        {solutions.map((s) => (
          <div class="col-lg-4 col-md-6 mt-4 pt-2 solution-item" data-categories={s.categories.join(",")}>
            <div class="card border-0 shadow h-100 d-flex flex-column solution-card overflow-hidden">
              <div class="sol-cover-wrap">
                <img src={s.cover} alt={s.title} class="sol-cover" loading="lazy" />
              </div>
              <div class="p-4 d-flex flex-column flex-grow-1">
                <h5 class="title text-dark mb-0">{s.title}</h5>
                <p class="text-muted mt-2 sol-desc">{s.desc}</p>
                <a href={s.href} class="text-primary small d-inline-block stretched-link">Lihat solusi <i class="uil uil-arrow-right"></i></a>
                <div class="solution-tags mt-3 pt-3 border-top">
                  {s.tags.map((t) => <span class="sol-tag">{t}</span>)}
                  {s.status && <span class="sol-tag sol-tag-status">{s.status}</span>}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- 空状态(暂未匹配) -->
      <div class="row" id="solution-empty" style="display:none;">
        <div class="col-12 text-center text-muted py-5">
          <i class="uil uil-search-minus h3 d-block mb-2"></i>Belum ada solusi di kategori ini, solusi lainnya segera hadir.
        </div>
      </div>
    </div>
  </section>
  <!-- Solutions Gallery End -->

  <ShapeFooter />

  <style>
    .solution-filter {
      display: inline-flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: center;
    }
    .filter-chip {
      cursor: pointer;
      padding: 6px 18px;
      border-radius: 30px;
      font-size: 14px;
      color: #6c757d;
      background: #f4f6fa;
      transition: all 0.2s ease;
      user-select: none;
    }
    .filter-chip:hover {
      color: #2f55d4;
      background: rgba(47, 85, 212, 0.08);
    }
    .filter-chip.active {
      color: #fff;
      background: #2f55d4;
    }
    .solution-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .sol-tag {
      font-size: 12px;
      padding: 2px 10px;
      border-radius: 20px;
      background: rgba(47, 85, 212, 0.1);
      color: #2f55d4;
      line-height: 1.6;
    }
    .sol-tag-status {
      background: rgba(46, 202, 139, 0.12);
      color: #2eca8b;
    }
    .sol-desc {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin-bottom: 1rem;
    }
    .solution-card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .solution-card:hover {
      transform: translateY(-4px);
    }
    .sol-cover-wrap {
      position: relative;
      width: 100%;
      height: 180px;
      overflow: hidden;
      background: #f4f6fa;
    }
    .sol-cover {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }
    .solution-card:hover .sol-cover {
      transform: scale(1.05);
    }
  </style>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const chips = document.querySelectorAll("#solution-filter .filter-chip");
      const items = document.querySelectorAll("#solution-grid .solution-item");
      const empty = document.getElementById("solution-empty");

      chips.forEach((chip) => {
        chip.addEventListener("click", () => {
          chips.forEach((c) => c.classList.remove("active"));
          chip.classList.add("active");
          const filter = chip.getAttribute("data-filter");
          let visible = 0;
          items.forEach((item) => {
            const cats = (item.getAttribute("data-categories") || "").split(",");
            const show = filter === "*" || cats.includes(filter);
            item.style.display = show ? "" : "none";
            if (show) visible++;
          });
          if (empty) empty.style.display = visible === 0 ? "" : "none";
        });
      });
    });
  </script>
</BaseID>
