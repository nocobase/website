---
import PageHeader from "../../../components/PageHeader.astro";
import Layout from "../../../layouts/Layout.astro";

const title = "Pegawai AI";
const description = "Lihat bagaimana pegawai AI NocoBase bekerja di dalam sistem bisnis Anda dan menjalankan tugas dengan konteks nyata.";
const keywords = "NocoBase, pegawai AI, AI bisnis, otomasi, agen";
---

<Layout title={title} description={description} keywords={keywords}>
  <PageHeader title={title}>
    <span slot="description">{description}</span>
  </PageHeader>
  <section class="section"><div class="container"><div class="row align-items-top "><div class="col-lg-5 col-md-5"><div class="section-title"><h5 class="mb-4">Pegawai AI bekerja <span class="text-primary">bersama Anda</span></h5><p class="text-muted">Di NocoBase, pegawai AI bukan sekadar chatbot atau agen yang berdiri sendiri. Mereka hadir langsung di dalam sistem bisnis, memahami konteks kerja, dan dapat mengeksekusi tugas secara nyata.</p></div></div><div class="col-lg-7"><div class="card rounded border-0 shadow ms-lg-5"><video controls class="rounded shadow"><source src="https://static-docs.nocobase.com/AE-3.1-EN.mp4" type="video/mp4"></video></div></div></div></div></section>
</Layout>
