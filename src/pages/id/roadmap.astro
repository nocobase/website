---
import PageHeader from "../../components/PageHeader.astro";
import Layout from "../../layouts/Layout.astro";

const title = "Roadmap";
const description = "Lihat roadmap NocoBase untuk mengikuti inisiatif yang sudah selesai dan yang sedang berjalan.";
const keywords = "NocoBase, roadmap, produk, fitur, pengembangan";
---

<Layout title={title} description={description} keywords={keywords}>
  <PageHeader title={title} description={description}>
  </PageHeader>

  <section class="section">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-9">
          <div class="card shadow border-0 rounded">
            <div class="card-body roadmap-body">
              <div class="roadmap-legend">
                <span class="legend-item">
                  <i class="uil uil-check-circle legend-icon legend-icon-done"></i>
                  <span>Selesai</span>
                </span>
                <span class="legend-item">
                  <i class="uil uil-clock-three legend-icon legend-icon-progress"></i>
                  <span>Sedang berjalan</span>
                </span>
              </div>

              <ul class="roadmap-list">
                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Peningkatan pegawai AI</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Antarmuka ekstensi AI di level kernel</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Dukungan integrasi dengan MCP</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Workflow: node pegawai AI</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Dukungan untuk sub-agent</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Dukungan sandbox dan skill kustom</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Dukungan multi-agent paralel</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">NocoBase MCP & CLI & Skills</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Membangun aplikasi NocoBase yang lengkap dengan agen coding lokal seperti Claude Code, Codex, dan OpenCode</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Menghubungkan agen lokal seperti OpenClaw ke NocoBase untuk alur bisnis</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Siklus AI penuh untuk pembangunan lokal, validasi, dan debugging otomatis</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>AI Worktree</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">IdP: OAuth</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Kompatibilitas dengan OAuth 2.1 dan OpenID Connect</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Memungkinkan NocoBase berperan sebagai penyedia identitas untuk login ke sistem lain</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Branch baru /v2/</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span><code>@nocobase/app</code> menyediakan client-v2</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Paket inti <code>@nocobase/client-v2</code></span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Setiap plugin menyertakan direktori <code>/src/client-v2</code></span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Rute baru <code>/v2/</code></span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-progress">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-clock-three align-middle"></i>
                      <span class="roadmap-title">Manajemen migrasi untuk merge dan rilis di banyak environment</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Sistem build berbasis Rsbuild</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span><code>yarn dev</code> dan <code>yarn dev:umi</code></span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Lazy loading plugin</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Peningkatan besar pada kecepatan muat awal aplikasi NocoBase</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Dukungan untuk JS Item Action</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Menyediakan berbagai jenis action</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Custom Request 2.0</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Aksi custom request</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Custom request di langkah workflow berbasis event-stream</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-progress">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-clock-three align-middle"></i>
                      <span class="roadmap-title">NocoBase Embed 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-progress">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-clock-three align-middle"></i>
                      <span class="roadmap-title">Variabel kustom</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-done">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-check-circle align-middle"></i>
                      <span class="roadmap-title">Tree block 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-done">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-check-circle align-middle"></i>
                      <span class="roadmap-title">Calendar block 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-done">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-check-circle align-middle"></i>
                      <span class="roadmap-title">Kanban block 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Migrasi penuh semua plugin ke client-v2</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Setiap plugin menyediakan dan meningkatkan <code>/src/client-v2</code></span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">UI Layout</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>Membuat layout fleksibel yang melampaui keterbatasan desktop dan mobile</span></li>
                  </ul>
                </li>
              </ul>
            </div>
          </div>
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
</Layout>

<style>
  .roadmap-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.25rem;
    padding: 0.85rem 1rem;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, #f8fbff 0%, #f5f7fb 100%);
    border: 1px solid #e9eef5;
  }

  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: #475569;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .legend-icon {
    font-size: 1rem;
  }

  .legend-icon-done {
    color: #16a34a;
  }

  .legend-icon-progress {
    color: #f59e0b;
  }

  .roadmap-list,
  .roadmap-list ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .roadmap-list > li {
    padding: 1rem 0 1.15rem;
    border-bottom: 1px solid #edf2f7;
  }

  .roadmap-list > li:first-child {
    padding-top: 0;
  }

  .roadmap-list > li:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .roadmap-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.55rem;
  }

  .roadmap-title {
    font-weight: 700;
    color: #0f172a;
  }

  .roadmap-item-status {
    margin-bottom: 0;
  }

  .roadmap-title-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .roadmap-list ul {
    margin-top: 0.25rem;
    padding-left: 1.5rem;
  }

  .roadmap-list ul li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    color: #475569;
    padding: 0.28rem 0;
    line-height: 1.65;
  }

  .roadmap-list ul li i,
  .roadmap-title-wrap i {
    margin-top: 0.2rem;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .status-done i {
    color: #16a34a;
  }

  .status-progress i {
    color: #f59e0b;
  }

  .roadmap-body code {
    background: #f1f5f9;
    color: #334155;
    border-radius: 0.35rem;
    padding: 0.12rem 0.4rem;
    font-size: 0.92em;
  }
</style>
