---
import PageHeader from "../../../components/PageHeader.astro";
import Layout from "../../../layouts/Layout.astro";

const title = "Permisos";
const description = "Gestiona permisos de sistema, permisos por registro y por campo en NocoBase con control detallado.";
const keywords = "NocoBase, permisos, roles, control de acceso, seguridad, datos";
---

<Layout title={title} description={description} keywords={keywords}>
  <PageHeader title={title}>
    <span slot="description">{description}</span>
  </PageHeader>
  <!-- Start Highlights -->
  <section class="section">
    <div class="container">
      <div class="row align-items-top ">
        <div class="col-lg-5 col-md-5">
          <div class="section-title">
            <h5 class="mb-4">Control de <span class="text-primary">permisos del sistema</span></h5>
            <p class="text-muted">Cuando desarrollas con NocoBase, puedes asignar distintos permisos del sistema a diferentes desarrolladores, asegurando que cada persona solo actúe sobre los módulos que tiene autorizados.</p>
          </div>
        </div><!--end col-->
        <div class="col-lg-7">
          <div class="card rounded border-0 shadow ms-lg-5">
            <video controls class="rounded shadow">
              <source src="https://static-docs.nocobase.com/PM-4.1-EN.mp4" type="video/mp4">
            </video>
          </div>
        </div><!--end col-->
      </div><!--end row-->
      <div class="row align-items-top mt-100">
        <div class="col-lg-5 col-md-5">
          <div class="section-title">
            <h5 class="mb-4">Control detallado de permisos <span class="text-primary">por registro y por campo</span></h5>
            <p class="text-muted">NocoBase admite un control muy granular tanto a nivel de registro como de campo, para que cada empleado solo pueda acceder y modificar la información que le corresponde.<br>Por ejemplo, un comercial puede ver y editar los clientes que gestiona, ver pero no editar los clientes de otros compañeros de su departamento y no ver el importe total de todos los pedidos.</p>
          </div>
        </div><!--end col-->
        <div class="col-lg-7">
          <div class="card rounded border-0 shadow ms-lg-5">
            <video controls class="rounded shadow">
              <source src="https://static-docs.nocobase.com/PM-4.2-EN.mp4" type="video/mp4">
            </video>
          </div>
        </div><!--end col-->
      </div><!--end row-->
      <div class="row align-items-top mt-100">
        <div class="col-lg-5 col-md-5">
          <div class="section-title">
            <h5 class="mb-4"><span class="text-primary">Múltiples roles</span> y permisos combinados para un mismo usuario</h5>
            <p class="text-muted">En los sistemas de negocio, un mismo usuario suele asumir varios roles a la vez. NocoBase permite asignar múltiples roles a una sola persona y ofrece tres estrategias de permisos para adaptarse a distintas necesidades.</p>
          </div>
        </div><!--end col-->
        <div class="col-lg-7">
          <div class="card rounded border-0 shadow ms-lg-5">
            <video controls class="rounded shadow">
              <source src="https://static-docs.nocobase.com/PM-4.3-EN.mp4" type="video/mp4">
            </video>
          </div>
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
  <!-- Highlights End -->
</Layout>
