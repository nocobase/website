---
import PageHeader from "../../../components/PageHeader.astro";
import Layout from "../../../layouts/Layout.astro";

const title = "Empleados de IA";
const description = "Descubre cómo los empleados de IA de NocoBase trabajan dentro del sistema de negocio y ejecutan tareas con contexto real.";
const keywords = "NocoBase, empleados de IA, IA empresarial, automatización, agentes";
---

<Layout title={title} description={description} keywords={keywords}>
  <PageHeader title={title}>
    <span slot="description">{description}</span>
  </PageHeader>
  <!-- Start Highlights -->
  <section class="section">
    <div class="container">
      <div class="row align-items-top ">
        <div class="col-lg-5 col-md-5">
          <div class="section-title">
            <h5 class="mb-4">Los empleados de IA trabajan <span class="text-primary">a tu lado</span></h5>
            <p class="text-muted">En NocoBase, los empleados de IA no son simples chatbots ni agentes aislados. Son compañeros inteligentes integrados de forma nativa en tu sistema de negocio, capaces de entender el contexto empresarial y ejecutar tareas directamente.</p>
          </div>
        </div><!--end col-->
        <div class="col-lg-7">
          <div class="card rounded border-0 shadow ms-lg-5">
            <video controls class="rounded shadow">
              <source src="https://static-docs.nocobase.com/AE-3.1-EN.mp4" type="video/mp4">
            </video>
          </div>
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
  <!-- Highlights End -->
</Layout>
