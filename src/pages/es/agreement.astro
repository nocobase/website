---
import PageHeader from "../../components/PageHeader.astro";
import Layout from "../../layouts/Layout.astro";
import { getPage } from "../../utils";

// Keep the legal agreement body in English as requested.
const page = await getPage("agreement", "en");

const title = "Acuerdo de licencia";
const description = "Consulta el acuerdo de licencia de NocoBase. El contenido legal se mantiene en inglés.";
const keywords = "NocoBase, acuerdo de licencia, licencia, términos legales";
---

<Layout title={title} description={description} keywords={keywords}>
  <PageHeader title={title} description={description}>
  </PageHeader>

  <!-- Start Agreement -->
  <section class="section">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-9">
          <div class="card shadow border-0 rounded">
            <div class="card-body license-body">
              <div set:html={page.content}></div>
            </div>
          </div>
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
  <!-- End agreement -->
</Layout>
