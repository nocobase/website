                            <td class="text-nowrap">Licencia comercial<a href="/es/agreement" target="_blank" class="text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Ver detalles"> <i class="fea icon-ex-md me-2 mt-1 uil uil-external-link-alt"></i></a></td>
                            <td class="text-nowrap">Licencia comercial<a href="/es/agreement" target="_blank" class="text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Ver detalles"> <i class="fea icon-ex-md me-2 mt-1 uil uil-external-link-alt"></i></a></td>
                            <td class="text-nowrap">Licencia comercial<a href="/es/agreement" target="_blank" class="text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Ver detalles"> <i class="fea icon-ex-md me-2 mt-1 uil uil-external-link-alt"></i></a></td>
                          </tr>
                          <tr>
                            <td class="compare-item text-muted text-nowrap">Licencia perpetua<a href="javascript:void" class="text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="La licencia es válida de por vida, lo que significa que puedes usar NocoBase de forma permanente sin volver a pagar."> <i class="fea icon-ex-md me-2 mt-1 uil uil-question-circle" style="font-size: 18px;"></i></a></td>
