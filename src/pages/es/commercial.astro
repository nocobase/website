---
import PageHeader from "../../components/PageHeader.astro";
import Layout from "../../layouts/Layout.astro";

const title = "Precios";
const description = "Mejoramos continuamente las capacidades centrales de NocoBase y lo mantenemos open source, al mismo tiempo que seguimos desarrollando mas plugins open source y gratuitos. La mayoria de las pequenas empresas y los equipos pueden cubrir sus necesidades con la Community Edition gratuita. Cuando tu negocio tiene mayores exigencias en funciones avanzadas, seguridad, arquitectura tecnica y soporte tecnico, puedes optar por la Commercial Edition.";
const keywords = "NocoBase, precios, licencias, edición community, edición standard, edición professional, edición enterprise";
---

<Layout title={title} description={description} keywords={keywords}>
  <PageHeader title={title} description={description} />
  <!-- Which Edition Start -->
  <section class="section pb-0" id="experience">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 text-center">
          <div class="section-title mb-4 pb-2">
            <div class="position-relative">
              <h4 class="title mb-4">Qué edición elegir</h4>
            </div>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="col-12 pt-2">
          <div class="timeline-page position-relative">
            <div class="timeline-item">
              <div class="row">
                <div class="col-lg-6 col-md-6 col-sm-6">
                  <div class="duration date-label-left position-relative text-md-end">
                    <h5>Edición Comunitaria, gratis</h5>
                    <small class="text-muted mb-0">La opción elegida por la mayoría</small>
                  </div>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 mt-4 mt-sm-0">
                  <div class="event event-description-right float-left text-start">
                    <h6 class="title mb-1 text-capitalize">Cuando necesitas</h6>
                    <ul class="text-muted">
                      <li>Una plataforma no-code impulsada por IA como infraestructura del equipo para crear sistemas de negocio y herramientas internas</li>
                      <li>Usar agentes de código conocidos para construir con IA</li>
                      <li>O construir manualmente con una interfaz no-code WYSIWYG, o combinar ambas formas de trabajo</li>
                      <li>Código fuente completo, despliegue propio y control total</li>
                      <li>Capacidades completas y amplias para cubrir la mayoría de necesidades</li>
                      <li>Incluye la mayor parte de las capacidades de empleados de IA</li>
                      <li>Libertad para ampliarla sin quedar atado a la plataforma y adaptarla a necesidades concretas</li>
                      <li>Crear aplicaciones ilimitadas, sin límite de usuarios ni de volumen de datos</li>
                      <li>Aceptar que aparezca un logotipo discreto de NocoBase en la interfaz</li>
                      <li>Soporte técnico a través de la comunidad de NocoBase</li>
                    </ul>
                  </div>
                </div><!--end col-->
              </div><!--end row-->
            </div><!--end timeline item-->

            <div class="timeline-item mt-5 pt-2">
              <div class="row">
                <div class="col-lg-6 col-md-6 col-sm-6">
                  <div class="duration date-label-left position-relative text-md-end">
                    <h5>Edición Estándar, 800 USD</h5>
                    <small class="text-muted mb-0">La mejor opción para un uso habitual</small>
                  </div>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 mt-4 mt-sm-0">
                  <div class="event event-description-right float-left text-start">
                    <h6 class="title mb-1 text-capitalize">Cuando además necesitas</h6>
                    <ul class="text-muted">
                      <li>Sustituir la marca de NocoBase en la interfaz por la tuya</li>
                      <li>Conectar bases de datos externas como MySQL o PostgreSQL a NocoBase como fuentes de datos</li>
                      <li>Importar o exportar grandes volúmenes de datos con Excel</li>
                      <li>Pago único para uso perpetuo</li>
                    </ul>
                  </div>
                </div><!--end col-->
              </div><!--end row-->
            </div><!--end timeline item-->

            <div class="timeline-item mt-5 pt-2">
              <div class="row">
                <div class="col-lg-6 col-md-6 col-sm-6">
                  <div class="duration date-label-left position-relative text-md-end">
                    <h5>Edición Profesional, 8.000 USD</h5>
                    <small class="text-muted mb-0">Pensada para cubrir las necesidades de equipos profesionales</small>
                  </div>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 mt-4 mt-sm-0">
                  <div class="event event-description-right float-left text-start">
                    <h6 class="title mb-1 text-capitalize">Cuando además necesitas</h6>
                    <ul class="text-muted">
                      <li>Crear aplicaciones para tus clientes con NocoBase</li>
                      <li>Dar capacidades avanzadas a los empleados de IA</li>
                      <li>Inicio de sesión único (SSO)</li>
                      <li>Funciones avanzadas de workflow como aprobaciones, subflujos y webhooks</li>
                      <li>Capacidades de seguridad más avanzadas</li>
                      <li>Registrar y mostrar el historial completo de edición de cada registro</li>
                      <li>Copias de seguridad automáticas programadas</li>
                      <li>Procesos de desarrollo más exigentes, con entornos de desarrollo, pruebas y producción</li>
                      <li>Acompañamiento dedicado de uso por parte del equipo de NocoBase</li>
                    </ul>
                  </div>
                </div><!--end col-->
              </div><!--end row-->
            </div><!--end timeline item-->

            <div class="timeline-item mt-5 pt-2">
              <div class="row">
                <div class="col-lg-6 col-md-6 col-sm-6">
                  <div class="duration date-label-left position-relative text-md-end">
                    <h5>Edición Enterprise, contáctanos</h5>
                    <small class="text-muted mb-0">Pensada para grandes aplicaciones y entornos empresariales</small>
                  </div>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 mt-4 mt-sm-0">
                  <div class="event event-description-right float-left text-start">
                    <h6 class="title mb-1 text-capitalize">Cuando además necesitas</h6>
                    <ul class="text-muted">
                      <li>Despliegue en clúster de aplicaciones NocoBase</li>
                      <li>Registro detallado de cada acción de usuario con fines de auditoría</li>
                      <li>Conectar fuentes de datos externas como Oracle, ClickHouse o Doris a NocoBase</li>
                      <li>Usar arquitectura multiaplicación para desplegar y gestionar varias aplicaciones en escenarios multi-tenant</li>
                      <li>Usar la función multiespacio para desplegar y gestionar varios espacios en escenarios multi-tienda o multi-fábrica</li>
                      <li>Requisitos profesionales de telemetría, incluidos logs, métricas de monitorización y trazas</li>
                      <li>Integrar Gmail, Outlook y otros servicios de correo, y usar funciones como aprobaciones con firma manuscrita</li>
                      <li>Dar capacidades avanzadas a los empleados de IA</li>
                      <li>Acceder al código fuente completo de la edición comercial</li>
                      <li>Prioridad para las funciones que necesitas dentro del roadmap de NocoBase</li>
                      <li>Respuesta más rápida y soporte dedicado durante más tiempo por parte del equipo de NocoBase</li>
                      <li>Soluciones dedicadas de desarrollo a medida por parte del equipo de NocoBase, incluidos plugins e integraciones de terceros</li>
                    </ul>
                  </div>
                </div><!--end col-->
              </div><!--end row-->
            </div><!--end timeline item-->


          </div><!--end timeline page-->
          <!-- TIMELINE END -->
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
  <!--Which Editon End-->

