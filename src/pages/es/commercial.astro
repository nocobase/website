                            <th scope="col" class="col-md-2 text-nowrap"><h5 class="text-primary mb-0">Edición Enterprise</h5></th>
                          </tr>
                          </thead>
                          <tbody>
                          <tr>
                            <td class="compare-item text-muted text-nowrap">Precio</td>
                            <td class="fw-bold fst-italic">Gratis</td>
