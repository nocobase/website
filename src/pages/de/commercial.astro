---
import PageHeader from "../../components/PageHeader.astro";
import Layout from "../../layouts/Layout.astro";

const title = "Preise";
const description = "Wir erweitern die Kernfunktionen von NocoBase kontinuierlich und halten es zugleich open source. Gleichzeitig entwickeln wir weitere open-source und kostenlose Plugins. Die meisten kleinen Unternehmen und Teams koennen ihre Anforderungen bereits mit der kostenlosen Community Edition abdecken. Wenn Ihr Unternehmen hoehere Anforderungen an erweiterte Funktionen, Sicherheit, technische Architektur und technischen Support hat, koennen Sie sich fuer die Commercial Edition entscheiden.";
const keywords = "NocoBase, Preise, Lizenzen, Community-Edition, Standard-Edition, Professional-Edition, Enterprise-Edition";
---

<Layout title={title} description={description} keywords={keywords}>
  <PageHeader title={title} description={description} />
  <!-- Which Edition Start -->
  <section class="section pb-0" id="experience">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 text-center">
          <div class="section-title mb-4 pb-2">
            <div class="position-relative">
              <h4 class="title mb-4">Welche Edition passt zu Ihnen</h4>
            </div>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="col-12 pt-2">
          <div class="timeline-page position-relative">
            <div class="timeline-item">
              <div class="row">
                <div class="col-lg-6 col-md-6 col-sm-6">
                  <div class="duration date-label-left position-relative text-md-end">
                    <h5>Community-Edition, kostenlos</h5>
                    <small class="text-muted mb-0">Die Wahl fuer die meisten Teams</small>
                  </div>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 mt-4 mt-sm-0">
                  <div class="event event-description-right float-left text-start">
                    <h6 class="title mb-1 text-capitalize">Wenn Sie Folgendes brauchen</h6>
                    <ul class="text-muted">
                      <li>Eine KI-gestuetzte No-Code-Plattform als Infrastruktur Ihres Teams fuer den Aufbau von Geschaeftssystemen und internen Tools</li>
                      <li>Nutzen Sie vertraute Coding-Agents fuer das Erstellen mit KI-Unterstuetzung</li>
                      <li>Oder bauen Sie manuell mit einer WYSIWYG-No-Code-Oberflaeche, beziehungsweise in einer Kombination aus beidem</li>
                      <li>Vollstaendiger Quellcode, Self-Hosting und volle Kontrolle</li>
                      <li>Umfangreiche und ausgereifte Funktionen fuer die meisten Anforderungen</li>
                      <li>Die meisten Faehigkeiten von KI-Mitarbeitern sind bereits enthalten</li>
                      <li>Freiheit zur Erweiterung ohne Lock-in und fuer individuelle Anforderungen</li>
                      <li>Erstellen Sie unbegrenzt Anwendungen ohne Limits bei Nutzern oder Datenvolumen</li>
                      <li>Akzeptieren Sie das dezente NocoBase-Logo in der Oberflaeche</li>
                      <li>Technischer Support aus der NocoBase-Community</li>
                    </ul>
                  </div>
                </div><!--end col-->
              </div><!--end row-->
            </div><!--end timeline item-->

            <div class="timeline-item mt-5 pt-2">
              <div class="row">
                <div class="col-lg-6 col-md-6 col-sm-6">
                  <div class="duration date-label-left position-relative text-md-end">
                    <h5>Standard-Edition, $800</h5>
                    <small class="text-muted mb-0">Die beste Wahl fuer den regelmaessigen Einsatz</small>
                  </div>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 mt-4 mt-sm-0">
                  <div class="event event-description-right float-left text-start">
                    <h6 class="title mb-1 text-capitalize">Wenn Sie zusaetzlich brauchen</h6>
                    <ul class="text-muted">
                      <li>Ersetzen Sie das NocoBase-Branding in der Oberflaeche durch Ihre eigene Marke</li>
                      <li>Binden Sie externe Datenbanken wie MySQL und PostgreSQL als Datenquellen in NocoBase ein</li>
                      <li>Importieren oder exportieren Sie grosse Datenmengen mit Excel</li>
                      <li>Einmalige Zahlung fuer dauerhafte Nutzung</li>
                    </ul>
                  </div>
                </div><!--end col-->
              </div><!--end row-->
            </div><!--end timeline item-->

            <div class="timeline-item mt-5 pt-2">
              <div class="row">
                <div class="col-lg-6 col-md-6 col-sm-6">
                  <div class="duration date-label-left position-relative text-md-end">
                    <h5>Professional-Edition, $8,000</h5>
                    <small class="text-muted mb-0">Fuer professionelle Teams ausgelegt</small>
                  </div>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 mt-4 mt-sm-0">
                  <div class="event event-description-right float-left text-start">
                    <h6 class="title mb-1 text-capitalize">Wenn Sie zusaetzlich brauchen</h6>
                    <ul class="text-muted">
                      <li>Entwickeln Sie mit NocoBase Anwendungen fuer Ihre Kunden</li>
                      <li>Geben Sie KI-Mitarbeitern erweiterte Faehigkeiten</li>
                      <li>Single sign-on (SSO)</li>
                      <li>Erweiterte Workflow-Funktionen wie Genehmigungen, Subflows und Webhooks</li>
                      <li>Staerkere Sicherheitsfunktionen</li>
                      <li>Erfassen und zeigen Sie die vollstaendige Bearbeitungshistorie jedes Datensatzes</li>
                      <li>Geplante automatische Datensicherungen</li>
                      <li>Hoehere Anforderungen an Entwicklungsablaeufe mit Entwicklungs-, Test- und Produktionsumgebungen</li>
                      <li>Dedizierte Nutzungsberatung durch das NocoBase-Team</li>
                    </ul>
                  </div>
                </div><!--end col-->
              </div><!--end row-->
            </div><!--end timeline item-->

            <div class="timeline-item mt-5 pt-2">
              <div class="row">
                <div class="col-lg-6 col-md-6 col-sm-6">
                  <div class="duration date-label-left position-relative text-md-end">
                    <h5>Enterprise-Edition, kontaktieren Sie uns</h5>
                    <small class="text-muted mb-0">Fuer grosse Anwendungen und Unternehmen ausgelegt</small>
                  </div>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 mt-4 mt-sm-0">
                  <div class="event event-description-right float-left text-start">
                    <h6 class="title mb-1 text-capitalize">Wenn Sie zusaetzlich brauchen</h6>
                    <ul class="text-muted">
                      <li>Cluster-Bereitstellung von NocoBase-Anwendungen</li>
                      <li>Detaillierte Protokollierung jeder Benutzeraktion fuer Audits</li>
                      <li>Binden Sie externe Datenquellen wie Oracle, ClickHouse und Doris in NocoBase ein</li>
                      <li>Nutzen Sie eine Multi-Application-Architektur, um mehrere Anwendungen fuer Multi-Tenant-Szenarien bereitzustellen und zu verwalten</li>
                      <li>Nutzen Sie die Multi-Space-Funktion, um mehrere Bereiche fuer Multi-Store- oder Multi-Factory-Szenarien bereitzustellen und zu verwalten</li>
                      <li>Professionelle Telemetrie-Anforderungen, einschliesslich Logs, Monitoring-Metriken und Tracing</li>
                      <li>Integrieren Sie Gmail, Outlook und andere E-Mail-Dienste und nutzen Sie Funktionen wie Freigaben mit handschriftlicher Signatur</li>
                      <li>Geben Sie KI-Mitarbeitern erweiterte Faehigkeiten</li>
                      <li>Erhalten Sie Zugriff auf den vollstaendigen Quellcode der kommerziellen Edition</li>
                      <li>Priorisierte Roadmap-Planung fuer die Funktionen, die Sie benoetigen</li>
                      <li>Schnellere Reaktionszeiten und laengerer dedizierter Support durch das NocoBase-Team</li>
                      <li>Dedizierte Loesungen fuer die Entwicklung von Erweiterungen durch das NocoBase-Team, einschliesslich Plugins und Drittanbieter-Integrationen</li>
                    </ul>
                  </div>
                </div><!--end col-->
              </div><!--end row-->
            </div><!--end timeline item-->


          </div><!--end timeline page-->
          <!-- TIMELINE END -->
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
