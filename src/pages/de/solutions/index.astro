---
import BaseDE from "../../../layouts/BaseDE.astro";
import ShapeFooter from "../../../components/ShapeFooter.astro";

// Lösungsbibliothek — um eine neue Lösung hinzuzufügen, einfach hier einen Eintrag anhängen
const solutions = [
  {
    title: "All-in-One Business Suite",
    desc: "CRM, Vertrieb, Tickets, Projekte, Anlagevermögen und HR — sechs Module in einem System vereint, mit integrierten KI-Mitarbeitern und Workflows.",
    href: "/de/solutions/all-in-one",
    cover: "https://static-docs.nocobase.com/all-in-one-cover-2026-05-20.jpg",
    icon: "uil-layer-group",
    categories: ["All-in-One"],
    status: "In Arbeit",
    tags: ["All-in-One", "Mehrere Geschäftsbereiche", "KI-Mitarbeiter"],
  },
  {
    title: "CRM Plus",
    desc: "Ein vollständiger Vertriebszyklus von Leads, Nachverfolgung und Konvertierung bis hin zu Customer 360. Modular und zerlegbar, tief integriert mit KI-Mitarbeitern, mit integrierter Mehrwährungsfunktion und Dashboards.",
    href: "/de/solutions/crm-v2",
    cover: "https://static-docs.nocobase.com/design-2026-02-01-02-46-56-opt.jpg",
    icon: "uil-chart-growth",
    categories: ["Kunden & Vertrieb"],
    tags: ["CRM", "Vertriebsmanagement", "Customer 360"],
  },
  {
    title: "CRM Basis",
    desc: "Ein flexibles, tief anpassbares CRM-Grundgerüst. Volle Datenhoheit, bereit zum Erweitern und Umgestalten darauf.",
    href: "/de/solutions/crm",
    cover: "https://static-docs.nocobase.com/img_v3_02o3_58bedc3b-7f22-4b56-9c74-83463ffb186g32-opt.jpeg",
    icon: "uil-users-alt",
    categories: ["Kunden & Vertrieb"],
    tags: ["CRM", "Anpassbar", "Grundgerüst"],
  },
  {
    title: "Intelligentes Ticketsystem 2.0",
    desc: "Der vollständige Lebenszyklus von der Kundenmeldung bis zum Fallabschluss. Eine T-förmige Datenarchitektur unterstützt mehrere Geschäftsszenarien, KI-Mitarbeiter unterstützen bei Klassifizierung und Bearbeitung.",
    href: "/de/solutions/ticketing-v2",
    cover: "https://static-docs.nocobase.com/ticketing-imgs-2026-01-01-00-46-12-opt.jpg",
    icon: "uil-robot",
    categories: ["Kundenservice"],
    tags: ["Tickets", "Support", "KI-Klassifizierung"],
  },
  {
    title: "Ticketsystem (1.x)",
    desc: "Eine wichtige Ergänzung zum CRM, bietet vollständiges Ticket-Lebenszyklusmanagement — ideal für After-Sales- und Kundenservice-Szenarien.",
    href: "/de/solutions/ticketing",
    cover: "https://static-docs.nocobase.com/img_v3_02o5_a2422688-f176-4c84-bf32-5ee0774f919g-1.png",
    icon: "uil-comment-alt-lines",
    categories: ["Kundenservice"],
    tags: ["Tickets", "After-Sales", "1.x"],
  },
  {
    title: "Projektmanagement (1.x)",
    desc: "Vollständiges Projekt-Lebenszyklusmanagement von der Anforderung bis zur Lieferung, umfasst Aufgaben, Iterationen, Fortschritt, Meilensteine und Arbeitsaufwand.",
    href: "/de/solutions/project-management",
    cover: "https://static-docs.nocobase.com/screenshot-20250909-151855-1.png",
    icon: "uil-clipboard-notes",
    categories: ["Projekte & F&E"],
    tags: ["Projekte", "F&E-Zusammenarbeit", "Meilensteine", "1.x"],
  },
];

// Filterkategorien (Reihenfolge ist Anzeigereihenfolge)
const categories = ["Alle", "All-in-One", "Kunden & Vertrieb", "Kundenservice", "Projekte & F&E"];
---

<BaseDE
  title="Weitere Lösungen - NocoBase Lösungsbibliothek"
  description="NocoBase Lösungsbibliothek: die All-in-One Business Suite sowie eigenständige Geschäftslösungen wie CRM, Vertrieb, Tickets und Projektmanagement. Nach Szenario filtern — alle basieren auf der NocoBase No-Code-Plattform, sofort einsatzbereit und selbst hostbar."
  keywords="NocoBase Lösungen, Lösungsbibliothek, All-in-One Business Suite, CRM-System, Ticketsystem, Projektmanagementsystem, No-Code-Lösungen, Open-Source-Geschäftssysteme"
>
  <!-- Hero Start -->
  <section class="bg-half-170 bg-light d-table w-100">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 text-center">
          <div class="title-heading">
            <h1 class="title fw-bold mb-3">Lösungsbibliothek</h1>
            <p class="para-desc mx-auto text-muted mb-0">
              Geschäftslösungen auf Basis der NocoBase No-Code-Plattform — wählen Sie die passende für Ihr Szenario. Alles ist sofort einsatzbereit und selbst hostbar, und ständig kommen neue Lösungen hinzu.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- Hero End -->

  <!-- Solutions Gallery Start -->
  <section class="section">
    <div class="container">
      <!-- Filter chips -->
      <div class="row justify-content-center">
        <div class="col-12 text-center mb-4">
          <ul class="solution-filter list-unstyled mb-0" id="solution-filter">
            {categories.map((cat, i) => (
              <li
                class:list={["filter-chip", { active: i === 0 }]}
                data-filter={cat === "Alle" ? "*" : cat}
              >{cat}</li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Kartengitter -->
      <div class="row" id="solution-grid">
        {solutions.map((s) => (
          <div class="col-lg-4 col-md-6 mt-4 pt-2 solution-item" data-categories={s.categories.join(",")}>
            <div class="card border-0 shadow h-100 d-flex flex-column solution-card overflow-hidden">
              <div class="sol-cover-wrap">
                <img src={s.cover} alt={s.title} class="sol-cover" loading="lazy" />
              </div>
              <div class="p-4 d-flex flex-column flex-grow-1">
                <h5 class="title text-dark mb-0">{s.title}</h5>
                <p class="text-muted mt-2 sol-desc">{s.desc}</p>
                <a href={s.href} class="text-primary small d-inline-block stretched-link">Lösung ansehen <i class="uil uil-arrow-right"></i></a>
                <div class="solution-tags mt-3 pt-3 border-top">
                  {s.tags.map((t) => <span class="sol-tag">{t}</span>)}
                  {s.status && <span class="sol-tag sol-tag-status">{s.status}</span>}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Leerer Zustand (noch keine Treffer) -->
      <div class="row" id="solution-empty" style="display:none;">
        <div class="col-12 text-center text-muted py-5">
          <i class="uil uil-search-minus h3 d-block mb-2"></i>In dieser Kategorie gibt es noch keine Lösungen — weitere sind in Vorbereitung.
        </div>
      </div>
    </div>
  </section>
  <!-- Solutions Gallery End -->

  <ShapeFooter />

  <style>
    .solution-filter {
      display: inline-flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: center;
    }
    .filter-chip {
      cursor: pointer;
      padding: 6px 18px;
      border-radius: 30px;
      font-size: 14px;
      color: #6c757d;
      background: #f4f6fa;
      transition: all 0.2s ease;
      user-select: none;
    }
    .filter-chip:hover {
      color: #2f55d4;
      background: rgba(47, 85, 212, 0.08);
    }
    .filter-chip.active {
      color: #fff;
      background: #2f55d4;
    }
    .solution-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .sol-tag {
      font-size: 12px;
      padding: 2px 10px;
      border-radius: 20px;
      background: rgba(47, 85, 212, 0.1);
      color: #2f55d4;
      line-height: 1.6;
    }
    .sol-tag-status {
      background: rgba(46, 202, 139, 0.12);
      color: #2eca8b;
    }
    .sol-desc {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin-bottom: 1rem;
    }
    .solution-card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .solution-card:hover {
      transform: translateY(-4px);
    }
    .sol-cover-wrap {
      position: relative;
      width: 100%;
      height: 180px;
      overflow: hidden;
      background: #f4f6fa;
    }
    .sol-cover {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }
    .solution-card:hover .sol-cover {
      transform: scale(1.05);
    }
  </style>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const chips = document.querySelectorAll("#solution-filter .filter-chip");
      const items = document.querySelectorAll("#solution-grid .solution-item");
      const empty = document.getElementById("solution-empty");

      chips.forEach((chip) => {
        chip.addEventListener("click", () => {
          chips.forEach((c) => c.classList.remove("active"));
          chip.classList.add("active");
          const filter = chip.getAttribute("data-filter");
          let visible = 0;
          items.forEach((item) => {
            const cats = (item.getAttribute("data-categories") || "").split(",");
            const show = filter === "*" || cats.includes(filter);
            item.style.display = show ? "" : "none";
            if (show) visible++;
          });
          if (empty) empty.style.display = visible === 0 ? "" : "none";
        });
      });
    });
  </script>
</BaseDE>
