---
import PageHeader from "../../components/PageHeader.astro";
import Layout from "../../layouts/Layout.astro";
import { getPage } from "../../utils";

const page = await getPage("roadmap");
const title = page.title_ja || page.title;
const description = page.description_ja || page.description;
const keywords = page.keywords_ja || page.keywords;
---

<Layout title={title} description={description} keywords={keywords}>
  <PageHeader title={title} description={description}>
  </PageHeader>

  <section class="section">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-9">
          <div class="card shadow border-0 rounded">
            <div class="card-body roadmap-body">
              <div class="roadmap-legend">
                <span class="legend-item">
                  <i class="uil uil-check-circle legend-icon legend-icon-done"></i>
                  <span>完了</span>
                </span>
                <span class="legend-item">
                  <i class="uil uil-clock-three legend-icon legend-icon-progress"></i>
                  <span>進行中</span>
                </span>
              </div>

              <ul class="roadmap-list">
                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">AI Employee の強化</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>カーネルレベルの AI 拡張インターフェース</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>MCP 連携のサポート</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>ワークフロー: AI Employee ノード</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Sub-agent のサポート</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>サンドボックス環境とカスタム Skill のサポート</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>複数 Agent の並列サポート</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">NocoBase MCP & CLI & Skills</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>Claude Code、Codex、OpenCode などのローカル Coding Agent で完全な NocoBase アプリを構築</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>OpenClaw などのローカル Agent を NocoBase に接続して業務フローを処理</span></li>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>ローカル構築、検証、自動デバッグまで含む AI の完全なループ</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>AI Worktree</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">IdP: OAuth</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>OAuth 2.1 と OpenID Connect のサポート</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>NocoBase を ID プロバイダーとして他システムにログイン可能にする</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">新しい /v2/ ブランチ</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span><code>@nocobase/app</code> が client-v2 を提供</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>コアパッケージ <code>@nocobase/client-v2</code></span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>各プラグインが <code>/src/client-v2</code> ディレクトリを提供</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>新しい <code>/v2/</code> ルート</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-progress">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-clock-three align-middle"></i>
                      <span class="roadmap-title">複数開発環境のマージとリリースに対応したマイグレーション管理</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">Rsbuild ベースのビルドシステム</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span><code>yarn dev</code> と <code>yarn dev:umi</code></span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">プラグインの遅延読み込み</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>NocoBase アプリの初回表示速度を大幅に改善</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">JS Item Action のサポート</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>さまざまな形の Action を提供</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">カスタムリクエスト 2.0</span>
                  </div>
                  <ul>
                    <li class="status-done"><i class="uil uil-check-circle align-middle"></i><span>カスタムリクエストアクション</span></li>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>イベントストリーム型ワークフローステップでのカスタムリクエスト対応</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-progress">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-clock-three align-middle"></i>
                      <span class="roadmap-title">NocoBase 埋め込み 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-progress">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-clock-three align-middle"></i>
                      <span class="roadmap-title">カスタム変数</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-done">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-check-circle align-middle"></i>
                      <span class="roadmap-title">ツリーブロック 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-done">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-check-circle align-middle"></i>
                      <span class="roadmap-title">カレンダーブロック 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item roadmap-item-status status-done">
                    <span class="roadmap-title-wrap">
                      <i class="uil uil-check-circle align-middle"></i>
                      <span class="roadmap-title">カンバンブロック 2.0</span>
                    </span>
                  </div>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">全プラグインの client-v2 への移行</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>各プラグインが <code>/src/client-v2</code> を提供・改善</span></li>
                  </ul>
                </li>

                <li>
                  <div class="roadmap-item">
                    <span class="roadmap-title">UI Layout</span>
                  </div>
                  <ul>
                    <li class="status-progress"><i class="uil uil-clock-three align-middle"></i><span>デスクトップやモバイルの制約を超えて柔軟なレイアウトを作成</span></li>
                  </ul>
                </li>
              </ul>
            </div>
          </div>
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
</Layout>

<style>
  .roadmap-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.25rem;
    padding: 0.85rem 1rem;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, #f8fbff 0%, #f5f7fb 100%);
    border: 1px solid #e9eef5;
  }

  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: #475569;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .legend-icon {
    font-size: 1rem;
  }

  .legend-icon-done {
    color: #16a34a;
  }

  .legend-icon-progress {
    color: #f59e0b;
  }

  .roadmap-list,
  .roadmap-list ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .roadmap-list > li {
    padding: 1rem 0 1.15rem;
    border-bottom: 1px solid #edf2f7;
  }

  .roadmap-list > li:first-child {
    padding-top: 0;
  }

  .roadmap-list > li:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .roadmap-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.55rem;
  }

  .roadmap-title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.5;
    color: #1e293b;
  }

  .roadmap-title-wrap {
    display: inline-flex;
    align-items: flex-start;
    gap: 0.65rem;
    min-width: 0;
  }

  .roadmap-item-status > .roadmap-title-wrap > i {
    margin-top: 0.18rem;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .roadmap-item-status.status-done > .roadmap-title-wrap > i {
    color: #16a34a;
  }

  .roadmap-item-status.status-progress > .roadmap-title-wrap > i {
    color: #f59e0b;
  }

  .roadmap-list ul {
    margin-top: 0.45rem;
    margin-left: 0.25rem;
    padding-left: 0.5rem;
    border-left: 2px solid #e9eef5;
  }

  .roadmap-list ul li {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    margin-top: 0.7rem;
    line-height: 1.7;
    color: #475569;
  }

  .roadmap-list ul li > i {
    margin-top: 0.2rem;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .roadmap-list ul li > span {
    flex: 1;
    min-width: 0;
  }

  .roadmap-list ul li.status-done > i {
    color: #16a34a;
  }

  .roadmap-list ul li.status-progress > i {
    color: #f59e0b;
  }

  .roadmap-body code {
    font-size: 0.875em;
    color: #e83e8c;
    background-color: #f8f9fa;
    padding: 0.15em 0.4em;
    border-radius: 3px;
  }

  @media (max-width: 576px) {
    .roadmap-item {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.4rem;
    }
  }
</style>
