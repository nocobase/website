---
import Layout from "../../layouts/Layout.astro";
import ShapeFooter from "../../components/ShapeFooter.astro";
---

<Layout
  title="Find a NocoBase Partner - Global Service Network for Your Project"
  description="NocoBase has a global network of partners providing system development, system integration, deployment, and maintenance services. Submit your requirements and we'll match you with the right service partner."
  keywords="NocoBase partner, find partner, system development, system integration, technical support, service implementation"
>
  <!-- Hero/Banner Start -->
  <section class="bg-half-170 bg-light d-table w-100">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 text-center">
          <div class="title-heading">
            <span class="badge bg-soft-primary mb-3">Find a Partner</span>
            <h1 class="fw-bold mt-2 mb-3">Find the Right NocoBase Partner to Drive Your Success</h1>
            <p class="para-desc mx-auto text-muted">NocoBase has a global network of partners providing system development, system integration, deployment, and maintenance services built on NocoBase, helping your project move forward with confidence.</p>
            <div class="mt-4 pt-2">
              <a href="#submit-requirements" class="btn btn-primary me-3">
                <i class="uil uil-file-edit-alt me-1"></i>Submit Requirements
              </a>
              <a href="#partner-fit" class="btn btn-outline-primary">
                <i class="uil uil-arrow-down me-1"></i>Learn More
              </a>
            </div>
          </div>
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
  <!-- Hero/Banner End -->

  <!-- Partner Fit Start -->
  <section class="section" id="partner-fit">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12">
          <div class="section-title text-center mb-4 pb-2">
            <h4 class="title mb-3">When Does It Make Sense to Work with a Partner?</h4>
            <p class="para-desc mx-auto text-muted mb-0">If you're facing any of the situations below, a NocoBase partner can help you move your project forward more efficiently.</p>
          </div>
        </div><!--end col-->
      </div><!--end row-->

      <div class="row">
        <div class="col-lg-4 col-md-6 mt-4 pt-2">
          <div class="card border-0 features feature-primary feature-clean course-feature p-4 overflow-hidden shadow h-100">
            <div class="icons text-start">
              <i class="uil uil-users-alt rounded h3 mb-0"></i>
            </div>
            <div class="card-body p-0 mt-4 d-flex flex-column">
              <h5 class="title text-dark mb-2">You Don't Have Enough In-House Developers</h5>
              <p class="text-muted">When your internal team lacks the bandwidth or implementation expertise, a partner can quickly fill the gap and keep the project moving.</p>
              <i class="uil uil-users-alt full-img"></i>
            </div>
          </div>
        </div><!--end col-->

        <div class="col-lg-4 col-md-6 mt-4 pt-2">
          <div class="card border-0 features feature-primary feature-clean course-feature p-4 overflow-hidden shadow h-100">
            <div class="icons text-start">
              <i class="uil uil-rocket rounded h3 mb-0"></i>
            </div>
            <div class="card-body p-0 mt-4 d-flex flex-column">
              <h5 class="title text-dark mb-2">You Need to Launch a Business System Quickly</h5>
              <p class="text-muted">If time-to-delivery matters, partner services can help shorten the path from planning to launch and reduce implementation risk.</p>
              <i class="uil uil-rocket full-img"></i>
            </div>
          </div>
        </div><!--end col-->

        <div class="col-lg-4 col-md-6 mt-4 pt-2">
          <div class="card border-0 features feature-primary feature-clean course-feature p-4 overflow-hidden shadow h-100">
            <div class="icons text-start">
              <i class="uil uil-setting rounded h3 mb-0"></i>
            </div>
            <div class="card-body p-0 mt-4 d-flex flex-column">
              <h5 class="title text-dark mb-2">You Need Custom Development, Training, or Maintenance</h5>
              <p class="text-muted">If you need more than just software and are looking for ongoing support, choosing partner services is the more reliable option.</p>
              <i class="uil uil-setting full-img"></i>
            </div>
          </div>
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
  <!-- Partner Fit End -->

  <!-- Services Start -->
  <section class="section">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12">
          <div class="section-title text-center mb-4 pb-2">
            <h4 class="title mb-4">What NocoBase Partners Can Do for You</h4>
            <p class="para-desc mx-auto text-muted mb-0">Whether it's a brand-new build or upgrading existing systems, NocoBase partners provide end-to-end professional services.</p>
          </div>
        </div><!--end col-->
      </div><!--end row-->

      <div class="row">
        <div class="col-lg-4 col-md-6 mt-4 pt-2">
          <div class="card border-0 features feature-primary feature-clean course-feature p-4 overflow-hidden shadow h-100">
            <div class="icons text-start">
              <i class="uil uil-laptop-cloud rounded h3 mb-0"></i>
            </div>
            <div class="card-body p-0 mt-4">
              <h5 class="title text-dark">System Development</h5>
              <p class="text-muted mt-2">Custom application development on the NocoBase platform tailored to your unique business needs. From requirements analysis and solution design to development and delivery — full-cycle professional services.</p>
              <i class="uil uil-laptop-cloud full-img"></i>
            </div>
          </div>
        </div><!--end col-->

        <div class="col-lg-4 col-md-6 mt-4 pt-2">
          <div class="card border-0 features feature-primary feature-clean course-feature p-4 overflow-hidden shadow h-100">
            <div class="icons text-start">
              <i class="uil uil-link-alt rounded h3 mb-0"></i>
            </div>
            <div class="card-body p-0 mt-4">
              <h5 class="title text-dark">System Integration</h5>
              <p class="text-muted mt-2">Seamlessly connect NocoBase with your existing ERP, CRM, OA, and other systems. Break down data silos and achieve automated, unified business process management.</p>
              <i class="uil uil-link-alt full-img"></i>
            </div>
          </div>
        </div><!--end col-->

        <div class="col-lg-4 col-md-6 mt-4 pt-2">
          <div class="card border-0 features feature-primary feature-clean course-feature p-4 overflow-hidden shadow h-100">
            <div class="icons text-start">
              <i class="uil uil-setting rounded h3 mb-0"></i>
            </div>
            <div class="card-body p-0 mt-4">
              <h5 class="title text-dark">Technical Support</h5>
              <p class="text-muted mt-2">Deployment, upgrade maintenance, performance optimization, and troubleshooting services to keep your NocoBase system running smoothly and efficiently.</p>
              <i class="uil uil-setting full-img"></i>
            </div>
          </div>
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
  <!-- Services End -->

  <!-- Submit Requirements Start -->
  <section class="section" id="submit-requirements">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 text-center">
          <h4 class="title mb-4">Submit Your Requirements</h4>
          <p class="text-muted para-desc mx-auto mb-4">
            Tell us about your project requirements, and we'll match you with the right NocoBase partner to help your project succeed.
          </p>
        </div><!--end col-->
      </div><!--end row-->
      <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
          <div class="card border-0 shadow rounded overflow-hidden">
            <iframe
              src="https://service-en.nocobase.com/public-forms/lf5m0yjz5dq"
              style="width: 100%; min-height: 700px; border: none;"
              loading="lazy"
            ></iframe>
          </div>
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
  <!-- Submit Requirements End -->

  <ShapeFooter />
</Layout>
