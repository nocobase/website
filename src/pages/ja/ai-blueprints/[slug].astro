---
import FormattedDate from "../../../components/FormattedDate.astro";
import PageHeader from "../../../components/PageHeader.astro";
import Toc from "../../../components/Toc.astro";
import Layout from "../../../layouts/Layout.astro";
import ImageZoom from "../../../components/ImageZoom.astro";
import { getLightSolution, listLightSolutions, url } from "../../../utils";
import { renderPromptSection } from "../../../utils/light-solution-prompt";
import JsonLd from "../../../components/JsonLd.astro";
import { generateBlueprintSchema } from "../../../seo/schema";

const { slug } = Astro.params;
const { data, headings, html } = await getLightSolution(slug, "ja");
if (!data || !data.title) {
  return new Response("Not found", { status: 404 });
}

// 関連 Blueprint: 同じタグを持つものを優先、自分自身を除外
const { data: allSolutions } = await listLightSolutions({ pageSize: 100 });
const currentTagIds = new Set((data.tags || []).map((t: any) => t.id));
const related = allSolutions
  .filter((s: any) => s.slug !== slug)
  .sort((a: any, b: any) => {
    const am = (a.tags || []).some((t: any) => currentTagIds.has(t.id)) ? 1 : 0;
    const bm = (b.tags || []).some((t: any) => currentTagIds.has(t.id)) ? 1 : 0;
    return bm - am;
  })
  .slice(0, 5);


// プロンプトカードの埋め込み: 本文中に独立行で書かれた {{prompt}} をプロンプトカードに差し替える
// マーカーがない場合はページ先頭にカードを表示
const promptSectionHtml = renderPromptSection(data.prompt_ja || data.prompt, "ja");
const bodyHtml = html.replace(/<p>\s*\{\{\s*prompt\s*\}\}\s*<\/p>/gi, "");

const title = data.title_ja || data.title;
const description = data.description_ja || data.description;
const keywords = (data.tags || []).map((tag: any) => tag.title_ja || tag.title).join(",");
const basepath = "/ja/ai-blueprints";
const tabs = [
  {
    title: "ホーム",
    link: "/ja/",
  },
  {
    title: "AI Blueprints",
    link: basepath,
  },
  {
    title: "詳細",
    active: true,
  },
];
const __canonical = "https://www.nocobase.com" + basepath + "/" + slug;
const __locale = basepath.split("/")[1] || "en";
const __crumbs = (tabs || []).map((t) => t.active ? { name: title, url: __canonical } : { name: t.title, url: "https://www.nocobase.com" + t.link });
const __jsonLd = generateBlueprintSchema({ locale: __locale, url: __canonical, title, description, datePublished: data.publishedAt, dateModified: data.updatedAt, author: data.author, image: data.cover?.url, tags: (data.tags || []).map((t) => t.title), breadcrumbs: __crumbs });
---

<Layout title={title} image={data.cover ? url(data.cover.url) : undefined} description={description} keywords={keywords}>
<JsonLd data={__jsonLd} />
  <PageHeader title={title} description={description} breadcrumb={tabs}>
    <div>
      {
        data.author && (
          <span title={data.author}>
            {data.author}
            <span style="opacity: 0.3; display:inline-block; padding: 0 .8em;">
              |
            </span>
          </span>
        )
      }
      <FormattedDate date={data.publishedAt || data.createdAt} locale="ja" />
    </div>
    <div class="solution-tags mt-2">
      {(data.tags || []).filter((t: any) => t.displayOnAiBlueprintPage !== false).map((t: any) => <span class="sol-tag">{t.title_ja || t.title}</span>)}
    </div>
  </PageHeader>
  <section class="section bg-white-color">
    <main class="container blog-container row">
      <div class="col-md-9 col-18 markdown-body">
        <Fragment set:html={promptSectionHtml} />
        <Fragment set:html={bodyHtml} />
      </div>
      <div class="col-md-3 col-6 markdown-toc">
        <div class="sticky-top side-stack" style="top: 80px;z-index: 0;">
          {headings.length > 0 && (
            <div class="toc-box">
              <Toc headings={headings} />
            </div>
          )}
          <div class="side-widgets">
            {related.length > 0 && (
              <div class="related-widget">
                <h6 class="widget-title">他の Blueprint</h6>
                <div class="mt-3">
                  {related.map((s: any) => (
                    <div class="d-flex align-items-center related-item">
                      {s.cover?.url ? (
                        <div class="related-thumb"><img src={s.cover.url} class="related-thumb-img" alt={s.title_ja || s.title} loading="lazy" /></div>
                      ) : (
                        <div class="related-thumb related-thumb-ph">{(s.title_ja || s.title || "?").slice(0, 1)}</div>
                      )}
                      <div class="flex-1 ms-3 overflow-hidden">
                        <a href={`/ja/ai-blueprints/${s.slug}`} class="d-block related-title text-dark text-truncate">{s.title_ja || s.title}</a>
                        {(s.tags || []).filter((t: any) => t.displayOnAiBlueprintPage !== false).length > 0 && (
                          <div class="related-tags">
                            {(s.tags || []).filter((t: any) => t.displayOnAiBlueprintPage !== false).slice(0, 2).map((t: any) => (
                              <span class="related-tag">{t.title}</span>
                            ))}
                          </div>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </main>
  </section>


  <ImageZoom />

  <style is:global>
    .solution-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      justify-content: center;
    }
    .sol-tag {
      font-size: 12px;
      padding: 2px 10px;
      border-radius: 20px;
      background: rgba(47, 85, 212, 0.1);
      color: #2f55d4;
      line-height: 1.6;
    }
    .prompt-card {
      border-radius: 12px;
      background: #f8f9fc;
    }
    .side-stack .headings {
      height: auto !important;
    }
    .side-stack {
      max-height: calc(100vh - 110px);
      display: flex;
      flex-direction: column;
      gap: 14px;
      overflow: hidden;
    }
    .toc-box {
      flex: 0 1 auto;
      max-height: 42vh;
      overflow-y: auto;
      overscroll-behavior: contain;
    }
    .toc-box::-webkit-scrollbar,
    .related-card .card-body::-webkit-scrollbar {
      width: 4px;
    }
    .toc-box::-webkit-scrollbar-thumb,
    .related-card .card-body::-webkit-scrollbar-thumb {
      background: #d6dbe5;
      border-radius: 2px;
    }
    .side-widgets {
      flex: 0 1 auto;
      min-height: 0;
      overflow-y: auto;
      overscroll-behavior: contain;
    }
    .side-widgets::-webkit-scrollbar {
      width: 4px;
    }
    .side-widgets::-webkit-scrollbar-thumb {
      background: #d6dbe5;
      border-radius: 2px;
    }
    .widget-title {
      font-weight: 600;
      font-size: 15px;
      margin-bottom: 0;
      color: #161c2d;
      background: #f8f9fa;
      text-align: center;
      padding: 8px 12px;
      border-radius: 6px;
      box-shadow: 0 0 3px rgba(60, 72, 88, 0.15);
    }
    .related-item {
      margin-bottom: 12px;
    }
    .related-item:last-child {
      margin-bottom: 0;
    }
    .related-thumb {
      width: 52px;
      height: 52px;
      border-radius: 6px;
      flex-shrink: 0;
      overflow: hidden;
    }
    .related-thumb-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transform: scale(1.25);
    }
    .related-thumb-ph {
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(47, 85, 212, 0.1);
      color: #2f55d4;
      font-weight: 600;
      font-size: 18px;
    }
    .related-title {
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      transition: color 0.2s ease;
    }
    .related-title:hover {
      color: #2f55d4 !important;
    }
    .related-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      margin-top: 3px;
    }
    .related-tag {
      font-size: 11px;
      padding: 1px 8px;
      border-radius: 10px;
      background: rgba(47, 85, 212, 0.08);
      color: #2f55d4;
      line-height: 1.6;
      white-space: nowrap;
      max-width: 100%;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .tagcloud a {
      display: inline-block;
      background: #f4f6fa;
      color: #3c4858;
      font-size: 12px;
      padding: 5px 12px;
      border-radius: 5px;
      margin: 0 6px 6px 0;
      text-decoration: none;
      transition: all 0.2s ease;
    }
    .tagcloud a:hover {
      background: #2f55d4;
      color: #fff;
    }
    .prompt-note {
      background: rgba(241, 180, 76, 0.12);
      border: 1px solid rgba(241, 180, 76, 0.4);
      color: #8a6116;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 13px;
      line-height: 1.7;
      margin-bottom: 12px;
    }
    .prompt-pre {
      background: #1e1e2e;
      color: #e6e6ef;
      border-radius: 8px;
      padding: 12px 14px;
      max-height: 180px;
      overflow: auto;
      white-space: pre-wrap;
      word-break: break-word;
      font-size: 12.5px;
      line-height: 1.6;
      margin-bottom: 8px;
    }
    .prompt-footnote {
      font-size: 12px;
      color: #8492a6;
      line-height: 1.7;
    }
    .prompt-footnote a {
      color: #2f55d4;
    }
  </style>

  <script>
    const btn = document.getElementById("copy-prompt");
    const pre = document.getElementById("solution-prompt");
    if (btn && pre) {
      const copyText = async (text: string) => {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(text);
          return;
        }
        // http などの非セキュアコンテキストでは clipboard API が使えないため、textarea にフォールバック
        const ta = document.createElement("textarea");
        ta.value = text;
        ta.style.position = "fixed";
        ta.style.opacity = "0";
        document.body.appendChild(ta);
        ta.select();
        document.execCommand("copy");
        ta.remove();
      };
      btn.addEventListener("click", async () => {
        try {
          await copyText(pre.textContent || "");
          btn.innerHTML = '<i class="uil uil-check"></i> コピーしました';
          setTimeout(() => {
            btn.innerHTML = '<i class="uil uil-copy"></i> プロンプトをコピー';
          }, 2000);
        } catch (e) {
          console.error("Copy failed", e);
        }
      });
    }
  </script>
</Layout>
