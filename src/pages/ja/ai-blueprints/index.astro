---
import BaseJA from "../../../layouts/BaseJA.astro";
import ShapeFooter from "../../../components/ShapeFooter.astro";
import { listLightSolutions } from "../../../utils";
import JsonLd from "../../../components/JsonLd.astro";
import { generateListSchema } from "../../../seo/schema";

// AI Blueprints — CMS から content/ai-blueprints/ に同期済み
const { data: solutions } = await listLightSolutions({ pageSize: 100 });

// フィルタータグ(実際に使われているタグを出現順で収集)
const tagTitles: string[] = [];
for (const s of solutions) {
  for (const t of (s.tags || []).filter((tg: any) => tg.displayOnAiBlueprint !== false)) {
    const label = t.title_ja || t.title;
    if (label && !tagTitles.includes(label)) tagTitles.push(label);
  }
}
const categories = ["すべて", ...tagTitles];
---

<BaseJA
  title="AI Blueprints - NocoBase"
  description="NocoBase AI Blueprints：すぐに使える標準プロンプト付きの小さな業務ソリューション集。AI エージェントに渡すだけで、あなた自身の NocoBase インスタンス上に同じシステムを再構築できます。"
  keywords="NocoBase AI Blueprints, AI エージェント プロンプト, ノーコード テンプレート, システム複製, オープンソース業務システム"
>
  <!-- Hero Start -->
  <section class="bg-half-170 bg-light d-table w-100">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 text-center">
          <div class="title-heading">
            <h1 class="title fw-bold mb-3">AI Blueprints</h1>
            <p class="para-desc mx-auto text-muted mb-0">
              NocoBase をベースにした、小さくて的を絞った業務ソリューション集です。各 Blueprint には標準プロンプトが付属しており、あなたの AI エージェントに渡すだけで、自分のインスタンス上に同じシステムを再構築できます。
            </p>
          </div>
        </div>
      </div>

      <!-- 検索バー -->
      <div class="row justify-content-center mt-4">
        <div class="col-lg-6 col-md-8">
          <div class="solution-search position-relative">
            <i class="uil uil-search search-icon"></i>
            <input
              type="text"
              id="solution-search"
              class="form-control"
              placeholder="Blueprint を検索..."
              autocomplete="off"
            />
          </div>
        </div>
      </div>

      <!-- フィルターチップ -->
      <div class="row justify-content-center mt-3">
        <div class="col-12 text-center">
          <ul class="solution-filter list-unstyled mb-0" id="solution-filter">
            {categories.map((cat, i) => (
              <li
                class:list={["filter-chip", { active: i === 0 }]}
                data-filter={cat === "すべて" ? "*" : cat}
              >{cat}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
  <!-- Hero End -->

  <!-- Solutions Gallery Start -->
  <section class="section pt-4">
    <div class="container">
      <!-- カードグリッド -->
      <div class="row" id="solution-grid">
        {solutions.map((s: any) => (
          <div class="col-lg-4 col-md-6 mt-4 pt-2 solution-item" data-categories={(s.tags || []).filter((tg: any) => tg.displayOnAiBlueprint !== false).map((t: any) => t.title_ja || t.title).join(",")} data-search={[s.title_ja || s.title, s.title, s.description_ja || s.description, ...(s.tags || []).map((t: any) => (t.title_ja || "") + " " + (t.title || ""))].join(" ").toLowerCase()}>
            <div class="card border-0 shadow h-100 d-flex flex-column solution-card overflow-hidden">
              {s.cover?.url && (
                <div class="sol-cover-wrap">
                  <img src={s.cover.url} alt={s.title_ja || s.title} class="sol-cover" loading="lazy" />
                </div>
              )}
              <div class="p-4 d-flex flex-column flex-grow-1">
                <h5 class="title text-dark mb-0">{s.title_ja || s.title}</h5>
                <p class="text-muted mt-2 sol-desc">{s.description_ja || s.description}</p>
                <a href={`/ja/ai-blueprints/${s.slug}`} class="text-primary small d-inline-block stretched-link">Blueprint を見る <i class="uil uil-arrow-right"></i></a>
                <div class="solution-tags mt-3 pt-3 border-top">
                  {(s.tags || []).filter((tg: any) => tg.displayOnAiBlueprint !== false).map((t: any) => <span class="sol-tag">{t.title_ja || t.title}</span>)}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- 空状態 -->
      <div class="row" id="solution-empty" style={solutions.length ? "display:none;" : ""}>
        <div class="col-12 text-center text-muted py-5">
          <i class="uil uil-search-minus h3 d-block mb-2"></i>このカテゴリにはまだ Blueprint がありません。続々追加予定です。
        </div>
      </div>
    </div>
  </section>
  <!-- Solutions Gallery End -->

  <ShapeFooter />

  <style>
    .solution-search .search-icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: #8492a6;
    }
    .solution-search input {
      padding: 10px 16px 10px 38px;
      border-radius: 30px;
      border: 1px solid #e9ecef;
      box-shadow: 0 2px 8px rgba(47, 85, 212, 0.06);
    }
    .solution-search input:focus {
      border-color: #2f55d4;
      box-shadow: 0 2px 12px rgba(47, 85, 212, 0.15);
    }
    .solution-filter {
      display: inline-flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: center;
    }
    .filter-chip {
      cursor: pointer;
      padding: 6px 18px;
      border-radius: 30px;
      font-size: 14px;
      color: #6c757d;
      background: #fff;
      border: 1px solid #e9ecef;
      transition: all 0.2s ease;
      user-select: none;
    }
    .filter-chip:hover {
      color: #2f55d4;
      background: rgba(47, 85, 212, 0.08);
    }
    .filter-chip.active {
      color: #fff;
      background: #2f55d4;
    }
    .solution-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .sol-tag {
      font-size: 12px;
      padding: 2px 10px;
      border-radius: 20px;
      background: rgba(47, 85, 212, 0.1);
      color: #2f55d4;
      line-height: 1.6;
    }
    .sol-desc {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin-bottom: 1rem;
    }
    .solution-card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .solution-card:hover {
      transform: translateY(-4px);
    }
    .sol-cover-wrap {
      position: relative;
      width: 100%;
      height: 180px;
      overflow: hidden;
      background: #f4f6fa;
    }
    .sol-cover {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }
    .solution-card:hover .sol-cover {
      transform: scale(1.05);
    }
  </style>

  <script>
    const chips = document.querySelectorAll<HTMLElement>("#solution-filter .filter-chip");
    const items = document.querySelectorAll<HTMLElement>("#solution-grid .solution-item");
    const empty = document.getElementById("solution-empty");
    const searchInput = document.getElementById("solution-search") as HTMLInputElement | null;

    let activeFilter = "*";

    function applyFilters() {
      const q = (searchInput?.value || "").trim().toLowerCase();
      let visible = 0;
      items.forEach((item) => {
        const cats = (item.dataset.categories || "").split(",");
        const text = item.dataset.search || "";
        const chipOk = activeFilter === "*" || cats.includes(activeFilter);
        const searchOk = !q || text.includes(q);
        const show = chipOk && searchOk;
        item.style.display = show ? "" : "none";
        if (show) visible++;
      });
      if (empty) empty.style.display = visible ? "none" : "";
    }

    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        chips.forEach((c) => c.classList.remove("active"));
        chip.classList.add("active");
        activeFilter = chip.dataset.filter || "*";
        applyFilters();
      });
    });

    searchInput?.addEventListener("input", applyFilters);

    // ?tag= パラメータがある場合は対応するフィルターチップを自動選択
    const tagParam = new URLSearchParams(location.search).get("tag");
    if (tagParam) {
      const hit = Array.from(chips).find((c) => c.dataset.filter === tagParam);
      if (hit) {
        chips.forEach((c) => c.classList.remove("active"));
        hit.classList.add("active");
        activeFilter = tagParam;
        applyFilters();
      }
    }
  </script>
<JsonLd data={generateListSchema({ locale: "ja", url: "/ja/ai-blueprints", name: "AI Blueprints - NocoBase", description: "NocoBase AI Blueprints：すぐに使える標準プロンプト付きの小さな業務ソリューション集。AI エージェントに渡すだけで、あなた自身の NocoBase インスタンス上に同じシステムを再構築できます。", kind: "CollectionPage", items: (solutions || []).map((s) => ({ name: s.title, url: "/ja/ai-blueprints/" + s.slug })), breadcrumbs: [ { name: "ホーム", url: "/ja/" }, { name: "AI Blueprints - NocoBase", url: "/ja/ai-blueprints" } ] })} />
</BaseJA>
