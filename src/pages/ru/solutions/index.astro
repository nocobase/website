---
import BaseRU from "../../../layouts/BaseRU.astro";
import ShapeFooter from "../../../components/ShapeFooter.astro";

// Библиотека решений — чтобы добавить новое решение, достаточно дописать сюда одну запись
const solutions = [
  {
    title: "All-in-One бизнес-пакет",
    desc: "CRM, продажи, тикеты, проекты, основные средства и HR — шесть модулей в одной системе, со встроенными ИИ-сотрудниками и рабочими процессами.",
    href: "/ru/solutions/all-in-one",
    cover: "https://static-docs.nocobase.com/all-in-one-cover-2026-05-20.jpg",
    icon: "uil-layer-group",
    categories: ["All-in-One"],
    status: "Обновляется",
    tags: ["All-in-One", "Несколько бизнес-линий", "ИИ-сотрудник"],
  },
  {
    title: "CRM Plus",
    desc: "Полный цикл продаж: лиды, сопровождение, конверсия и клиент 360°; модули разделяемы, глубоко интегрированы с ИИ-сотрудниками, со встроенной мультивалютностью и дашбордами.",
    href: "/ru/solutions/crm-v2",
    cover: "https://static-docs.nocobase.com/design-2026-02-01-02-46-56-opt.jpg",
    icon: "uil-chart-growth",
    categories: ["Клиенты и продажи"],
    tags: ["CRM", "Управление продажами", "Клиент 360°"],
  },
  {
    title: "CRM Базовый",
    desc: "Гибкая, глубоко настраиваемая базовая платформа CRM с полным суверенитетом над данными, готовая к расширению и доработке.",
    href: "/ru/solutions/crm",
    cover: "https://static-docs.nocobase.com/img_v3_02o3_58bedc3b-7f22-4b56-9c74-83463ffb186g32-opt.jpeg",
    icon: "uil-users-alt",
    categories: ["Клиенты и продажи"],
    tags: ["CRM", "Настраиваемый", "Основа"],
  },
  {
    title: "Умная тикет-система 2.0",
    desc: "Полный жизненный цикл от регистрации обращения клиента до закрытия; T-образная архитектура данных поддерживает множество бизнес-сценариев, ИИ-сотрудники помогают с классификацией и обработкой.",
    href: "/ru/solutions/ticketing-v2",
    cover: "https://static-docs.nocobase.com/ticketing-imgs-2026-01-01-00-46-12-opt.jpg",
    icon: "uil-robot",
    categories: ["Обслуживание клиентов"],
    tags: ["Тикеты", "Поддержка", "ИИ-классификация"],
  },
  {
    title: "Система тикетов (1.x)",
    desc: "Важное дополнение к CRM: полное управление жизненным циклом тикетов, подходит для постпродажного обслуживания и поддержки.",
    href: "/ru/solutions/ticketing",
    cover: "https://static-docs.nocobase.com/img_v3_02o5_a2422688-f176-4c84-bf32-5ee0774f919g-1.png",
    icon: "uil-comment-alt-lines",
    categories: ["Обслуживание клиентов"],
    tags: ["Тикеты", "Постпродажа", "1.x"],
  },
  {
    title: "Управление проектами (1.x)",
    desc: "Полное управление жизненным циклом проекта от требований до сдачи, охватывающее задачи, итерации, прогресс, вехи и трудозатраты.",
    href: "/ru/solutions/project-management",
    cover: "https://static-docs.nocobase.com/screenshot-20250909-151855-1.png",
    icon: "uil-clipboard-notes",
    categories: ["Проекты и R&D"],
    tags: ["Проекты", "Совместная разработка", "Вехи", "1.x"],
  },
];

// Категории фильтра (порядок — это порядок отображения)
const categories = ["Все", "All-in-One", "Клиенты и продажи", "Обслуживание клиентов", "Проекты и R&D"];
---

<BaseRU
  title="Больше решений - Библиотека решений NocoBase"
  description="Библиотека решений NocoBase: All-in-One бизнес-пакет, а также независимые решения для CRM, продаж, тикетов и управления проектами, фильтруемые по сценарию, все на основе no-code платформы NocoBase, готовые к работе и self-hosted."
  keywords="решения NocoBase, библиотека решений, All-in-One бизнес-пакет, CRM-система, тикет-система, система управления проектами, no-code решение, open source бизнес-система"
>
  <!-- Hero Start -->
  <section class="bg-half-170 bg-light d-table w-100">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 text-center">
          <div class="title-heading">
            <h1 class="title fw-bold mb-3">Библиотека решений</h1>
            <p class="para-desc mx-auto text-muted mb-0">
              Бизнес-решения, наработанные на no-code платформе NocoBase, выбирайте по сценарию то, что подходит именно вам. Все готовы к работе и поддерживают self-hosting, новые решения выходят постоянно.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- Hero End -->

  <!-- Solutions Gallery Start -->
  <section class="section">
    <div class="container">
      <!-- фильтр chips -->
      <div class="row justify-content-center">
        <div class="col-12 text-center mb-4">
          <ul class="solution-filter list-unstyled mb-0" id="solution-filter">
            {categories.map((cat, i) => (
              <li
                class:list={["filter-chip", { active: i === 0 }]}
                data-filter={cat === "Все" ? "*" : cat}
              >{cat}</li>
            ))}
          </ul>
        </div>
      </div>

      <!-- сетка карточек -->
      <div class="row" id="solution-grid">
        {solutions.map((s) => (
          <div class="col-lg-4 col-md-6 mt-4 pt-2 solution-item" data-categories={s.categories.join(",")}>
            <div class="card border-0 shadow h-100 d-flex flex-column solution-card overflow-hidden">
              <div class="sol-cover-wrap">
                <img src={s.cover} alt={s.title} class="sol-cover" loading="lazy" />
              </div>
              <div class="p-4 d-flex flex-column flex-grow-1">
                <h5 class="title text-dark mb-0">{s.title}</h5>
                <p class="text-muted mt-2 sol-desc">{s.desc}</p>
                <a href={s.href} class="text-primary small d-inline-block stretched-link">Открыть решение <i class="uil uil-arrow-right"></i></a>
                <div class="solution-tags mt-3 pt-3 border-top">
                  {s.tags.map((t) => <span class="sol-tag">{t}</span>)}
                  {s.status && <span class="sol-tag sol-tag-status">{s.status}</span>}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- пустое состояние (нет совпадений) -->
      <div class="row" id="solution-empty" style="display:none;">
        <div class="col-12 text-center text-muted py-5">
          <i class="uil uil-search-minus h3 d-block mb-2"></i>В этой категории пока нет решений, новые решения уже в пути.
        </div>
      </div>
    </div>
  </section>
  <!-- Solutions Gallery End -->

  <ShapeFooter />

  <style>
    .solution-filter {
      display: inline-flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: center;
    }
    .filter-chip {
      cursor: pointer;
      padding: 6px 18px;
      border-radius: 30px;
      font-size: 14px;
      color: #6c757d;
      background: #f4f6fa;
      transition: all 0.2s ease;
      user-select: none;
    }
    .filter-chip:hover {
      color: #2f55d4;
      background: rgba(47, 85, 212, 0.08);
    }
    .filter-chip.active {
      color: #fff;
      background: #2f55d4;
    }
    .solution-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .sol-tag {
      font-size: 12px;
      padding: 2px 10px;
      border-radius: 20px;
      background: rgba(47, 85, 212, 0.1);
      color: #2f55d4;
      line-height: 1.6;
    }
    .sol-tag-status {
      background: rgba(46, 202, 139, 0.12);
      color: #2eca8b;
    }
    .sol-desc {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin-bottom: 1rem;
    }
    .solution-card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .solution-card:hover {
      transform: translateY(-4px);
    }
    .sol-cover-wrap {
      position: relative;
      width: 100%;
      height: 180px;
      overflow: hidden;
      background: #f4f6fa;
    }
    .sol-cover {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }
    .solution-card:hover .sol-cover {
      transform: scale(1.05);
    }
  </style>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const chips = document.querySelectorAll("#solution-filter .filter-chip");
      const items = document.querySelectorAll("#solution-grid .solution-item");
      const empty = document.getElementById("solution-empty");

      chips.forEach((chip) => {
        chip.addEventListener("click", () => {
          chips.forEach((c) => c.classList.remove("active"));
          chip.classList.add("active");
          const filter = chip.getAttribute("data-filter");
          let visible = 0;
          items.forEach((item) => {
            const cats = (item.getAttribute("data-categories") || "").split(",");
            const show = filter === "*" || cats.includes(filter);
            item.style.display = show ? "" : "none";
            if (show) visible++;
          });
          if (empty) empty.style.display = visible === 0 ? "" : "none";
        });
      });
    });
  </script>
</BaseRU>
