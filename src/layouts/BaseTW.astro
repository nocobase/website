---
import ShapeFooter from "../components/ShapeFooter.astro";
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import DocSearch from "../components/DocSearch.astro";
import { listLightSolutions } from "../utils";

const { data: lightSolutions } = await listLightSolutions({ pageSize: 5 });

const year = new Date().getFullYear();
const baseClassName = Astro.url.pathname.split("/")?.[2] || "";

// 定義支持的語言列表
const supportedLanguages = ['en', 'es', 'pt', 'id', 'vi', 'de', 'cn', 'tw', 'ja', 'fr'];
// 獲取當前路徑
const currentPath = Astro.url.pathname;

// 正則表達式匹配多語言路徑前綴
const langPrefixRegex = /^\/(en|es|pt|id|vi|de|cn|tw|ja|fr)(\/|$)/;

// 函數用於生成不同語言的 URL
const generateUrl = (lang: string) => {
  if (langPrefixRegex.test(currentPath)) {
    // 替換現有的語言前綴
    return currentPath.replace(langPrefixRegex, `/${lang}/`);
  } else {
    // 如果沒有語言前綴，則添加新的語言前綴
    return `/${lang}${currentPath}`;
  }
};

// 生成各語言的 URL
let urlCN = generateUrl('cn').replace(/\/$/, '');
let urlTW = generateUrl('tw').replace(/\/$/, ''); // 移除結尾的斜槓以避免重複
let urlES = generateUrl('es').replace(/\/$/, '');
let urlPT = generateUrl('pt').replace(/\/$/, '');
let urlID = generateUrl('id').replace(/\/$/, '');
let urlVI = generateUrl('vi').replace(/\/$/, '');
let urlDE = generateUrl('de').replace(/\/$/, '');
let urlJA = generateUrl('ja').replace(/\/$/, '');
let urlEN = generateUrl('en').replace(/\/$/, '');
let urlFR = generateUrl('fr').replace(/\/$/, '');

// 特殊處理根路徑
if (currentPath === '/tw' || currentPath === '/en' || currentPath === '/es' || currentPath === '/ja' || currentPath === '/fr') {
  urlCN = '/cn';
  urlTW = '/tw';
  urlEN = '/';
  urlES = '/es';
  urlPT = '/pt';
  urlID = '/id';
  urlVI = '/vi';
  urlDE = '/de';
  urlJA = '/ja';
  urlFR = '/fr';
}

// 確保英文主頁是 '/'
if (urlEN === '/en') {
  urlEN = '/';
}

const { title, description, keywords, image } = Astro.props;

const meta = {
  image: image || 'https://static-docs.nocobase.com/20260513-og-github-v3.jpg',
  title: title
      ? `${title} - NocoBase`
      : "NocoBase - 開源、私有部署的 AI 驅動的零代碼和低代碼開發平臺",
  description:
      description ||
      "NocoBase 是一個開源的 “AI + 無代碼” 開發平臺，用於快速開發企業業務系統。不同於讓 AI 從零生成代碼，NocoBase 提供經過生產驗證的基礎設施和所見即所得的無代碼界面，讓 AI 與人高效協同，既保證開發速度又保證系統可靠性。",
  keywords:
      keywords ||
      "nocobase,AI,AI員工,AI Employees,Claude code,Codex,Deepseek,OpenCode,低代碼,無代碼,零代碼,私有部署,開源,no-code,low-code,open-source,零代碼開發,低代碼開發,工作流管理軟件,業務流程管理,協作軟件,企業流程管理,企業管理系統,零代碼系統,零代碼平臺,零代碼搭建,免費零代碼開發平臺,無代碼系統,無代碼平臺,無代碼搭建,免費無代碼開發平臺",
};
