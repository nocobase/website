    <!-- common  -->
    <style>
      /* Add media query to ensure it only takes effect on mobile */
      @media (max-width: 991px) {
        #navigation {
          position: fixed;  /* Change to fixed positioning */
          width: 100%;
          top: 0;
          left: 0;
          background: white; /* Ensure background color */
          z-index: 99; /* Set appropriate z-index */
        }
        
        #topnav {
          z-index: 100; /* Ensure header is above navigation */
        }
      }
    </style>

    <script>
      function updateNavigationPosition() {
        if (window.innerWidth <= 991) {  // Only handle on mobile
          const header = document.getElementById('topnav');
          const navigation = document.getElementById('navigation');
          if (header && navigation) {
            const headerHeight = header.offsetHeight;
            navigation.style.top = `${headerHeight}px`;
            
            // Add event listener to handle menu expand/collapse
            const toggle = document.getElementById('isToggle');
            if (toggle) {
              toggle.addEventListener('click', () => {
                setTimeout(updateNavigationPosition, 10); // Short delay to ensure DOM updates
              });
            }
          }
        } else {
          // Reset desktop styles
          const navigation = document.getElementById('navigation');
          if (navigation) {
            navigation.style.top = '';
          }
        }
      }

      // Update position on page load and window resize
      window.addEventListener('load', updateNavigationPosition);
      window.addEventListener('resize', updateNavigationPosition);
      
      // Monitor DOM changes in case header height changes dynamically
      const observer = new MutationObserver(updateNavigationPosition);
      const header = document.getElementById('topnav');
      if (header) {
        observer.observe(header, { 
          subtree: true, 
          childList: true,
          attributes: true 
        });
      }

    </script>
